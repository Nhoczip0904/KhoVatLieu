@code {
    private bool isOpen = false;
    private string activeTab = "chat"; // "chat" or "settings"
    private string userInput = string.Empty;
    private bool isGenerating = false;
    private bool showApiKey = false;
    private bool showSavedAlert = false;

    private List<AiService.ChatMessage> messages = new();
    private AiService.AiSettings settings = new();

    protected override async Task OnInitializedAsync()
    {
        // Add a default welcoming message
        messages.Add(new AiService.ChatMessage
        {
            Role = "model",
            Text = "Xin chào! Tôi là **Trợ lý AI cá nhân hóa** của bạn. Tôi có thể giúp bạn kiểm tra tồn kho, cảnh báo vật tư sắp hết, xem nhanh doanh thu dự án và tình trạng công nợ. Hãy hỏi tôi bất cứ điều gì!"
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load settings from localStorage
            try
            {
                var storedNickname = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ai_nickname");
                var storedPersona = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ai_persona");
                var storedStyle = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ai_style");
                var storedApiKey = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ai_apikey");
                var storedProvider = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ai_provider");
                var storedOllamaUrl = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ai_ollama_url");
                var storedOllamaModel = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ai_ollama_model");

                if (!string.IsNullOrEmpty(storedNickname)) settings.UserNickname = storedNickname;
                if (!string.IsNullOrEmpty(storedPersona)) settings.Persona = storedPersona;
                if (!string.IsNullOrEmpty(storedStyle)) settings.LanguageStyle = storedStyle;
                if (!string.IsNullOrEmpty(storedApiKey)) settings.ApiKey = storedApiKey;
                if (!string.IsNullOrEmpty(storedProvider)) settings.Provider = storedProvider;
                if (!string.IsNullOrEmpty(storedOllamaUrl)) settings.OllamaUrl = storedOllamaUrl;
                if (!string.IsNullOrEmpty(storedOllamaModel)) settings.OllamaModel = storedOllamaModel;

                StateHasChanged();
            }
            catch { }
        }
    }

    private void ToggleDrawer()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            ScrollToBottom();
        }
    }

    private void CloseDrawer()
    {
        isOpen = false;
    }

    private void ChangeTab(string tab)
    {
        activeTab = tab;
        showSavedAlert = false;
        if (tab == "chat")
        {
            ScrollToBottom();
        }
    }

    private void ToggleApiKeyVisibility()
    {
        showApiKey = !showApiKey;
    }

    private async Task SaveSettingsAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ai_nickname", settings.UserNickname);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ai_persona", settings.Persona);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ai_style", settings.LanguageStyle);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ai_apikey", settings.ApiKey);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ai_provider", settings.Provider);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ai_ollama_url", settings.OllamaUrl);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ai_ollama_model", settings.OllamaModel);

            showSavedAlert = true;
            
            // Auto-hide alert after 3 seconds
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() =>
            {
                showSavedAlert = false;
                StateHasChanged();
            }));

            // Reset conversation starting with custom greeting referencing user nickname
            messages.Clear();
            messages.Add(new AiService.ChatMessage
            {
                Role = "model",
                Text = $"Chào **{settings.UserNickname}**! Cấu hình trợ lý đã được cập nhật thành công. Trực giác AI của tôi hiện đã được chuyển sang chế độ: **{GetPersonaBadge()}**. Tôi có thể giúp gì cho bạn hôm nay?"
            });

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving AI settings: {ex.Message}");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessageAsync();
        }
    }

    private async Task SendSuggestedPromptAsync(string promptText)
    {
        userInput = promptText;
        await SendMessageAsync();
    }

    private async Task SendMessageAsync()
    {
        if (isGenerating || string.IsNullOrWhiteSpace(userInput)) return;

        var userMessage = userInput.Trim();
        userInput = string.Empty;

        // Add user message to UI
        messages.Add(new AiService.ChatMessage
        {
            Role = "user",
            Text = userMessage
        });

        isGenerating = true;
        StateHasChanged();
        ScrollToBottom();

        // Get AI Response
        var response = await AiService.GenerateResponseAsync(messages, settings);

        // Add AI response to UI
        messages.Add(new AiService.ChatMessage
        {
            Role = "model",
            Text = response
        });

        isGenerating = false;
        StateHasChanged();
        ScrollToBottom();
    }

    private void ScrollToBottom()
    {
        // Simple JS helper execution to scroll to the bottom of the chat list
        _ = Task.Delay(50).ContinueWith(async _ =>
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", "const el = document.getElementById('chat-history-body'); if(el) el.scrollTop = el.scrollHeight;");
            }
            catch { }
        });
    }

    private string GetPersonaBadge()
    {
        return settings.Persona switch
        {
            "serious" => "Thủ kho nghiêm túc",
            "financial" => "Cố vấn tài chính",
            _ => "Trợ lý thân thiện"
        };
    }

    private MarkupString ConvertMarkdownToHtml(string markdown)
    {
        if (string.IsNullOrEmpty(markdown)) return new MarkupString("");
        
        // Escape special chars to prevent script injections
        var html = markdown
            .Replace("&", "&amp;")
            .Replace("<", "&lt;")
            .Replace(">", "&gt;");
            
        // 1. Headers (### Header)
        html = System.Text.RegularExpressions.Regex.Replace(html, @"### (.*?)(?=\n|$)", "<h6 style='font-weight: 800; margin: 0.5rem 0 0.25rem 0;'>$1</h6>");
        
        // 2. Bold text (**text**)
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.*?)\*\*", "<strong>$1</strong>");

        // 3. Icons or Alert emojis styling
        html = html.Replace("⚠️", "<span style='color:#f59e0b;'>⚠️</span>")
                   .Replace("❌", "<span style='color:#ef4444;'>❌</span>")
                   .Replace("🤖", "<span style='color:#2563eb;'>🤖</span>")
                   .Replace("📊", "<span style='color:#3b82f6;'>📊</span>")
                   .Replace("💸", "<span style='color:#10b981;'>💸</span>")
                   .Replace("🚚", "<span style='color:#8b5cf6;'>🚚</span>")
                   .Replace("✅", "<span style='color:#10b981;'>✅</span>");

        // 4. Bullet points formatting (- line)
        var lines = html.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.None);
        var inList = false;
        var processedLines = new List<string>();
        
        foreach (var line in lines)
        {
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("- ") || trimmed.StartsWith("* "))
            {
                var content = trimmed.Substring(2);
                if (!inList)
                {
                    processedLines.Add("<ul style='padding-left: 1.1rem; margin-bottom: 0.5rem; margin-top: 0.25rem;'>");
                    inList = true;
                }
                processedLines.Add($"<li style='margin-bottom: 0.15rem;'>{content}</li>");
            }
            else
            {
                if (inList)
                {
                    processedLines.Add("</ul>");
                    inList = false;
                }
                processedLines.Add(line + "<br/>");
            }
        }
        if (inList)
        {
            processedLines.Add("</ul>");
        }
        
        html = string.Join("\n", processedLines);
        return new MarkupString(html);
    }
    private AiService.AiAction? pendingAction;
    private bool isExecutingAction = false;
    private HashSet<int> executedActions = new();

    private async Task ExecuteActionAsync(AiService.AiAction action, int msgHash)
    {
        isExecutingAction = true;
        StateHasChanged();

        try
        {
            string resultMessage;
            switch (action.Type)
            {
                case "create_project":
                    // Phát sự kiện sang trang Projects để mở form điền sẵn
                    AiActionBridgeService.TriggerAction("create_project", action.Data, action.Materials);
                    
                    // Chuyển hướng và đóng drawer
                    NavigationManager.NavigateTo("/projects");
                    CloseDrawer();
                    
                    resultMessage = $"🔄 **Đang chuyển hướng...** Đã mở form thiết lập dự án mới cho khách hàng **{action.Data.GetValueOrDefault("customerName", "")}**.";
                    break;

                case "add_customer":
                    var customer = new Customer
                    {
                        Name = action.Data.GetValueOrDefault("name", ""),
                        Phone = action.Data.GetValueOrDefault("phone"),
                        Address = action.Data.GetValueOrDefault("address"),
                        Note = action.Data.GetValueOrDefault("note")
                    };
                    await WarehouseService.AddCustomerAsync(customer);
                    resultMessage = $"✅ **Đã thêm khách hàng thành công!** Khách hàng **{customer.Name}** đã được lưu vào danh sách.";
                    break;

                case "record_payment":
                    var projectIdStr = action.Data.GetValueOrDefault("projectId", "0");
                    var amountStr = action.Data.GetValueOrDefault("amount", "0");
                    if (int.TryParse(projectIdStr, out var projId) && decimal.TryParse(amountStr.Replace(",", ""), out var amount))
                    {
                        var payment = new Payment
                        {
                            ProjectId = projId,
                            Amount = amount,
                            Method = action.Data.GetValueOrDefault("method", "Tiền mặt"),
                            Note = action.Data.GetValueOrDefault("note", "Ghi nhận qua Trợ lý AI"),
                            Timestamp = DateTime.Now
                        };
                        await WarehouseService.AddPaymentAsync(payment);
                        resultMessage = $"✅ **Đã ghi nhận thanh toán thành công!** Số tiền **{amount:N0} VNĐ** cho dự án ID **{projId}**.";
                    }
                    else
                    {
                        resultMessage = "❌ **Lỗi:** Không thể xác định ID dự án hoặc số tiền thanh toán.";
                    }
                    break;

                default:
                    resultMessage = $"⚠️ Thao tác **{action.Type}** chưa được hỗ trợ.";
                    break;
            }

            executedActions.Add(msgHash);
            messages.Add(new AiService.ChatMessage { Role = "model", Text = resultMessage });
        }
        catch (Exception ex)
        {
            messages.Add(new AiService.ChatMessage { Role = "model", Text = $"❌ **Lỗi thực hiện:** {ex.Message}" });
        }

        isExecutingAction = false;
        pendingAction = null;
        StateHasChanged();
        ScrollToBottom();
    }

    private void RejectAction(AiService.ChatMessage msg)
    {
        executedActions.Add(msg.Text.GetHashCode());
        messages.Add(new AiService.ChatMessage { Role = "model", Text = "👌 Đã hủy thao tác. Nếu bạn cần gì khác, hãy cho em biết nhé!" });
        StateHasChanged();
        ScrollToBottom();
    }

