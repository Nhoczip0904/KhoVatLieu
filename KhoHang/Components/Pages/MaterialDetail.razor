@page "/material/{Id:int}"
@using KhoHang.Models
@using KhoHang.Services
@inject WarehouseService WarehouseService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="custom-scrollbar" style="height: 100vh; overflow-y: auto; background: #f1f5f9; padding: 2rem;">
    @if (isLoading)
    {
        <div style="display: flex; justify-content: center; align-items: center; height: 100%;">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (material == null)
    {
        <div style="text-align: center; padding: 4rem 2rem;">
            <i class="bi bi-x-circle text-danger" style="font-size: 3rem;"></i>
            <h3 style="margin-top: 1rem;">Không tìm thấy vật tư</h3>
            <button class="btn-primary mt-3" @onclick='() => Nav.NavigateTo("/")'>Về trang chủ</button>
        </div>
    }
    else
    {
        <div style="max-width: 1200px; margin: 0 auto;">
            <!-- Header Section -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <button class="btn-outline" style="width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center;" @onclick='() => Nav.NavigateTo("/catalog")'>
                        <i class="bi bi-arrow-left"></i>
                    </button>
                    <div>
                        <h1 style="margin: 0; font-size: 1.75rem; font-weight: 800; font-family: 'Outfit'; color: #0f172a;">@material.Name</h1>
                        <div style="font-size: 0.9rem; color: var(--text-secondary); font-weight: 600;">@material.Category?.Name | ĐVT: @material.Unit</div>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem;">
                     <div class="glass-card" style="padding: 0.75rem 1.5rem; text-align: center; background: white; border: 1px solid var(--accent-primary);">
                        <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Tổng tồn kho</div>
                        <div style="font-size: 1.5rem; font-weight: 900; color: var(--accent-primary);">@material.StockQty.ToString("0.##") <span style="font-size: 0.8rem;">@material.Unit</span></div>
                    </div>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 350px 1fr; gap: 2rem;">
                <!-- Left Column: Info & Lots -->
                <div style="display: flex; flex-direction: column; gap: 2rem;">
                    <!-- Product Card -->
                    <div class="glass-card" style="padding: 0; overflow: hidden; background: white;">
                        <div style="width: 100%; height: 250px; background: #f8fafc; display: flex; justify-content: center; align-items: center;">
                            @if (!string.IsNullOrEmpty(material.ImageUrl))
                            {
                                <img src="@material.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="bi bi-box-seam" style="font-size: 4rem; color: #cbd5e1;"></i>
                            }
                        </div>
                        <div style="padding: 1.5rem;">
                            <div style="font-size: 0.75rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; margin-bottom: 0.75rem;">Thông tin chi tiết</div>
                            <div style="display: flex; flex-direction: column; gap: 1rem;">
                                <div style="display: flex; justify-content: space-between;">
                                    <span style="color: var(--text-secondary);">Nhà cung cấp</span>
                                    <span style="font-weight: 700;">@(material.Supplier?.Name ?? "N/A")</span>
                                </div>
                                <div style="display: flex; justify-content: space-between;">
                                    <span style="color: var(--text-secondary);">Mã sản phẩm</span>
                                    <span style="font-weight: 700;">@(material.ProductCode ?? "---")</span>
                                </div>
                                <div style="display: flex; justify-content: space-between;">
                                    <span style="color: var(--text-secondary);">Giá nhập gần nhất</span>
                                    <span style="font-weight: 700;">@(material.Lots.OrderByDescending(l => l.Id).FirstOrDefault()?.CostPrice.ToString("N0") ?? "0") đ</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Lots List -->
                    <div class="glass-card" style="background: white;">
                        <h3 style="font-size: 1.1rem; font-weight: 800; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
                            <i class="bi bi-layers text-primary"></i> Danh sách các Lô
                        </h3>
                        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                            @foreach (var lot in material.Lots.OrderBy(l => l.LotNumber))
                            {
                                <div style="padding: 1rem; background: #f8fafc; border-radius: 12px; border: 1px solid #e2e8f0;">
                                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                                        <div style="font-weight: 800; color: #1e293b;">Lô: @lot.LotNumber</div>
                                        <div style="font-size: 1.1rem; font-weight: 900; color: @(lot.StockQty > 0 ? "var(--accent-primary)" : "#94a3b8");">@lot.StockQty.ToString("0.##")</div>
                                    </div>
                                    <div style="font-size: 0.75rem; color: var(--text-secondary);">
                                        <div><i class="bi bi-calendar-event"></i> HSD: @(lot.ProductionDate?.ToString("dd/MM/yyyy") ?? "---")</div>
                                        @if (!string.IsNullOrEmpty(lot.Note))
                                        {
                                            <div style="margin-top: 0.25rem; font-style: italic; color: #64748b;">"@lot.Note"</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Right Column: Projects & History -->
                <div style="display: flex; flex-direction: column; gap: 2rem;">
                    
                    <!-- Section: Reconciliation Project & Batch -->
                    <div class="glass-card" style="background: white; padding: 1.5rem; border-radius: 20px;">
                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
                            <div style="width: 32px; height: 32px; border-radius: 8px; background: #eef2ff; color: #6366f1; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-briefcase"></i>
                            </div>
                            <h3 style="margin: 0; font-size: 1.1rem; font-weight: 800; color: #1e293b;">Đối chiếu Dự án & Lô hàng</h3>
                        </div>

                        @if (!commitments.Any())
                        {
                            <div style="text-align: center; padding: 2rem; color: var(--text-muted); font-size: 0.9rem;">Không có dự án nào đăng ký vật tư này.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table" style="font-size: 0.85rem; vertical-align: middle;">
                                    <thead style="background: #f8fafc;">
                                        <tr>
                                            <th style="border: none; padding: 1rem; border-radius: 8px 0 0 8px;">LÔ / DỰ ÁN</th>
                                            <th style="border: none; padding: 1rem;" class="text-center">DỰ KIẾN (TỔNG)</th>
                                            <th style="border: none; padding: 1rem;" class="text-center">ĐÃ GIAO</th>
                                            <th style="border: none; padding: 1rem; border-radius: 0 8px 8px 0;" class="text-end">CÒN LẠI</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var activeLots = material.Lots.OrderBy(l => l.Id).ToList();
                                        }
                                        @foreach (var lot in activeLots)
                                        {
                                            var lotCommitments = commitments.Where(c => c.TargetLotNumber == lot.LotNumber).ToList();
                                            var totalLotPromised = lotCommitments.Sum(c => c.RemainingQty);
                                            var isShortage = totalLotPromised > lot.StockQty + 0.0001;

                                            <!-- Lot Header Summary -->
                                            <tr style="background: @(isShortage ? "#fff1f2" : "#f0f9ff");">
                                                <td style="padding: 0.75rem 1rem; border-top: 1px solid #e2e8f0;">
                                                    <div style="display: flex; align-items: center; gap: 8px;">
                                                        <span style="font-weight: 900; color: #0369a1;">LÔ: @lot.LotNumber</span>
                                                        <span style="font-size: 0.7rem; background: white; padding: 2px 6px; border-radius: 4px; border: 1px solid #bae6fd; color: #0369a1;">Tồn thực tế: @lot.StockQty.ToString("0.##")</span>
                                                    </div>
                                                </td>
                                                <td class="text-center" style="padding: 0.75rem 1rem; border-top: 1px solid #e2e8f0; font-weight: 800; color: @(isShortage ? "#be123c" : "#0f172a")">
                                                    @totalLotPromised.ToString("0.##")
                                                </td>
                                                <td colspan="2" class="text-end" style="padding: 0.75rem 1rem; border-top: 1px solid #e2e8f0;">
                                                    @if (isShortage)
                                                    {
                                                        <span style="color: #be123c; font-weight: 800; font-size: 0.7rem;"><i class="bi bi-exclamation-triangle-fill"></i> THIẾU: @((totalLotPromised - lot.StockQty).ToString("0.##"))</span>
                                                    }
                                                    else
                                                    {
                                                        <span style="color: #059669; font-weight: 800; font-size: 0.7rem;"><i class="bi bi-check-circle-fill"></i> AN TOÀN</span>
                                                    }
                                                </td>
                                            </tr>

                                            <!-- Projects tied to this lot -->
                                            @foreach (var c in lotCommitments)
                                            {
                                                <tr>
                                                    <td style="padding: 0.75rem 1rem; padding-left: 2rem;">
                                                        <div style="font-weight: 600; color: #475569; cursor: pointer;" @onclick='() => Nav.NavigateTo($"/projects/{c.ProjectId}")'>
                                                            @(!string.IsNullOrWhiteSpace(c.Project?.CustomerName) ? c.Project.CustomerName : $"Dự án #{c.ProjectId}")
                                                        </div>
                                                        <div style="font-size: 0.7rem; color: #94a3b8;">Dự án: @(!string.IsNullOrWhiteSpace(c.Project?.CustomerName) ? c.Project.CustomerName : "Chưa đặt tên")</div>
                                                    </td>
                                                    <td class="text-center" style="color: #64748b;">@c.TotalQty.ToString("0.##")</td>
                                                    <td class="text-center" style="color: #64748b;">@((c.TotalQty - c.RemainingQty).ToString("0.##"))</td>
                                                    <td class="text-end" style="font-weight: 700; color: var(--accent-primary);">@c.RemainingQty.ToString("0.##")</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <!-- Section: Transaction History -->
                    <div class="glass-card" style="background: white;">
                         <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                            <h3 style="font-size: 1.1rem; font-weight: 800; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                                <i class="bi bi-clock-history text-primary"></i> Lịch sử Xuất - Nhập - Trả
                            </h3>
                        </div>

                        <!-- History Filters -->
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; background: #f8fafc; padding: 1rem; border-radius: 12px; border: 1px solid #e2e8f0;">
                            <div>
                                <label style="font-size: 0.65rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.35rem; display: block;">Loại</label>
                                <select class="form-select-modern" style="padding: 0.35rem; font-size: 0.8rem;" @bind="filterType" @bind:after="ApplyFilters">
                                    <option value="">Tất cả</option>
                                    <option value="Nhập">Nhập kho</option>
                                    <option value="Xuất">Xuất kho</option>
                                    <option value="Trả hàng">Trả hàng</option>
                                    <option value="Điều chỉnh">Điều chỉnh</option>
                                </select>
                            </div>
                            <div>
                                <label style="font-size: 0.65rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.35rem; display: block;">Từ ngày</label>
                                <input type="date" class="form-input-modern" style="padding: 0.35rem; font-size: 0.8rem;" @bind="fromDate" @bind:after="ApplyFilters" />
                            </div>
                            <div>
                                <label style="font-size: 0.65rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.35rem; display: block;">Đến ngày</label>
                                <input type="date" class="form-input-modern" style="padding: 0.35rem; font-size: 0.8rem;" @bind="toDate" @bind:after="ApplyFilters" />
                            </div>
                        </div>

                        <div style="max-height: 500px; overflow-y: auto; padding-right: 0.5rem; scrollbar-width: thin;">
                            @if (!pagedTransactions.Any())
                            {
                                <div style="text-align: center; padding: 2rem; color: var(--text-muted); font-size: 0.9rem;">Không có lịch sử giao dịch nào phù hợp.</div>
                            }
                            else
                            {
                                @foreach (var trans in pagedTransactions)
                                {
                                    <div style="display: flex; gap: 1rem; padding-bottom: 1rem; border-bottom: 1px solid #f1f5f9; margin-bottom: 1rem;">
                                        <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background: @(GetTransBg(trans.Type)); color: @(GetTransColor(trans.Type));">
                                            <i class="bi @(GetTransIcon(trans.Type))" style="font-size: 1.2rem;"></i>
                                        </div>
                                        <div style="flex: 1;">
                                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                                <div style="font-weight: 700; color: #1e293b;">@trans.Type</div>
                                                <div style="font-weight: 900; font-size: 1.1rem; color: @(trans.QtyChange > 0 ? "var(--success)" : "var(--error)");">
                                                    @(trans.QtyChange > 0 ? "+" : "")@trans.QtyChange.ToString("0.##")
                                                </div>
                                            </div>
                                            <div style="font-size: 0.85rem; color: #64748b; margin-top: 0.25rem;">
                                                @if (!string.IsNullOrEmpty(trans.LotNumber)) { <span style="font-weight: 700; color: var(--accent-primary);">Lô: @trans.LotNumber</span> <text>|</text> }
                                                <span>@trans.Note</span>
                                            </div>
                                            <div style="font-size: 0.75rem; color: #94a3b8; margin-top: 0.4rem;">
                                                <i class="bi bi-clock"></i> @trans.Timestamp.ToString("HH:mm dd/MM/yyyy")
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        
                        <!-- Pagination (Outside scroll area for visibility) -->
                        @if (totalPages > 1)
                        {
                            <div style="display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #f1f5f9;">
                                <button class="btn-outline" style="padding: 0.25rem 0.75rem; font-size: 0.75rem;" disabled="@(currentPage == 1)" @onclick="() => { currentPage--; }">Trước</button>
                                <span style="font-size: 0.8rem; font-weight: 700; color: #64748b;">Trang @currentPage / @totalPages</span>
                                <button class="btn-outline" style="padding: 0.25rem 0.75rem; font-size: 0.75rem;" disabled="@(currentPage >= totalPages)" @onclick="() => { currentPage++; }">Tiếp</button>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Material? material;
    private List<InventoryTransaction> transactions = new();
    private List<ProjectMaterial> commitments = new();
    private bool isLoading = true;

    // Filters & Pagination
    private string filterType = "";
    private DateTime? fromDate = DateTime.Today.AddDays(-30);
    private DateTime? toDate = DateTime.Today;
    private int currentPage = 1;
    private int pageSize = 10;

    private List<InventoryTransaction> filteredTransactions => transactions
        .Where(t => string.IsNullOrEmpty(filterType) || t.Type == filterType)
        .Where(t => fromDate == null || t.Timestamp.Date >= fromDate.Value.Date)
        .Where(t => toDate == null || t.Timestamp.Date <= toDate.Value.Date)
        .ToList();

    private IEnumerable<InventoryTransaction> pagedTransactions => filteredTransactions
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private int totalPages => Math.Max(1, (int)Math.Ceiling(filteredTransactions.Count / (double)pageSize));

    private void ApplyFilters() => currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        material = await WarehouseService.GetMaterialByIdAsync(Id);
        if (material != null)
        {
            transactions = await WarehouseService.GetInventoryTransactionsByMaterialIdAsync(Id);
            commitments = await WarehouseService.GetActiveProjectCommitmentsAsync(Id);
        }
        isLoading = false;
    }

    private string GetTransIcon(string type) => type switch
    {
        "Nhập kho" or "Nhập" => "bi-download",
        "Xuất kho" or "Xuất" => "bi-upload",
        "Khách trả hàng" or "Trả hàng" => "bi-arrow-return-left",
        "Điều chỉnh" => "bi-pencil",
        _ => "bi-arrow-repeat"
    };

    private string GetTransColor(string type) => type switch
    {
        "Nhập kho" or "Nhập" => "#059669",
        "Xuất kho" or "Xuất" => "#dc2626",
        "Khách trả hàng" or "Trả hàng" => "#d97706",
        "Điều chỉnh" => "#2563eb",
        _ => "#4b5563"
    };

    private string GetTransBg(string type) => type switch
    {
        "Nhập kho" or "Nhập" => "#ecfdf5",
        "Xuất kho" or "Xuất" => "#fef2f2",
        "Khách trả hàng" or "Trả hàng" => "#fffbeb",
        "Điều chỉnh" => "#eff6ff",
        _ => "#f9fafb"
    };
}
