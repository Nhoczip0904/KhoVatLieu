@code {
    [Parameter] public int Id { get; set; }
    private Project? project;
    private List<Delivery> deliveries = new();
    private List<CustomerReturn> customerReturns = new();
    private bool showToast = false;
    private string toastMessage = "";
    // Delivery fields (Dynamic List)
    public class DraftItem
    {
        public int ProjectMaterialId { get; set; }
        public int MaterialId { get; set; }
        public string Name { get; set; } = "";
        public string Unit { get; set; } = "";
        public decimal Qty { get; set; }
        public decimal Price { get; set; }
        public string LotNumber { get; set; } = "";
        public bool IsReturn { get; set; }
    }

    private List<DraftItem> draftItems = new();
    private Dictionary<int, List<MaterialLot>> availableLots = new();
    private bool isProcessing = false;
    private bool isSelectionModalOpen = false;
    private bool isEditInfoModalOpen = false;
    private bool isReturnModalOpen = false;
    private bool showDeliveryReview = false;
    private string? promisedWarning;
    private bool isConfiguringMaterials = false;
    private bool isEditingSingleMaterial = false;
    private bool isPaymentModalOpen = false;
    private ProjectMaterial? materialToEdit;
    private List<ProjectMaterial> selectedMaterialsToConfig = new();
    private Delivery? previewDelivery;
    private bool showCompleteConfirm = false;

    // Payment fields
    private decimal paymentAmount = 0;
    private string paymentMethod = "Tiền mặt";
    private string paymentNote = "";

    // Return fields
    private Dictionary<int, double> returnItems = new();
    private Dictionary<int, decimal> returnPrices = new();
    private Dictionary<int, string> returnLots = new();
    private string returnNote = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectData();
    }

    private Dictionary<int, string> overallWarnings = new();

    private async Task LoadProjectData()
    {
        project = await WarehouseService.GetProjectByIdAsync(Id);
        if (project != null)
        {
            deliveries = await WarehouseService.GetDeliveriesByProjectIdAsync(Id);
            customerReturns = await WarehouseService.GetCustomerReturnsByProjectIdAsync(Id);
            
            if (draftItems == null) draftItems = new();
            
            // Load available lots for each material
            foreach (var m in project.Materials)
            {
                var lots = await WarehouseService.GetMaterialLotsAsync(m.MaterialId);
                availableLots[m.MaterialId] = lots;
            }

            await RefreshOverallWarnings();
        }
    }

    private async Task RefreshOverallWarnings()
    {
        overallWarnings.Clear();
        if (project == null) return;

        foreach (var m in project.Materials)
        {
            if (m.RemainingQty <= 0) continue;

            var mainMat = await WarehouseService.GetMaterialByIdAsync(m.MaterialId);
            if (mainMat == null) continue;

            if (!string.IsNullOrEmpty(m.TargetLotNumber))
            {
                var lot = mainMat.Lots.FirstOrDefault(l => l.LotNumber == m.TargetLotNumber);
                var lotStock = lot?.StockQty ?? 0;
                var totalPromised = await WarehouseService.GetTotalPromisedQtyAsync(m.MaterialId, m.TargetLotNumber);
                
                if (totalPromised > lotStock + 0.0001)
                {
                    overallWarnings[m.Id] = $"CẢNH BÁO: Lô '{m.TargetLotNumber}' không đủ hàng cho TẤT CẢ dự án (Tổng thiếu: {(totalPromised - lotStock).ToString("0.##")} {m.Unit})";
                }
            }
        }
    }

    // Alias for compatibility with existing calls
    private Task LoadData() => LoadProjectData();

    private async Task UpdateProjectInfo()
    {
        if (project == null) return;
        await WarehouseService.UpdateProjectAsync(project);
        isEditInfoModalOpen = false;
        StateHasChanged();
    }

    private async Task AddExtraRow(ProjectMaterial m)
    {
        if (draftItems.Any(i => i.ProjectMaterialId == m.Id)) return;

        if (m.RemainingQty <= 0)
        {
            toastMessage = $"Vật tư <b>'{m.Name}'</b> đã giao đủ!\nCần nhập thêm dự trù vào kho của khách.";
            showToast = true;
            StateHasChanged();
            await Task.Delay(5000);
            showToast = false;
            StateHasChanged();
            return;
        }

        var newItem = new DraftItem {
            ProjectMaterialId = m.Id,
            MaterialId = m.MaterialId,
            Name = m.Name,
            Unit = m.Unit,
            Qty = 0,
            Price = m.CustomPrice,
            LotNumber = m.TargetLotNumber
        };

        // Cập nhật giá nếu lô này có giá bán riêng
        if (!string.IsNullOrEmpty(newItem.LotNumber) && availableLots.ContainsKey(m.MaterialId))
        {
            var targetLot = availableLots[m.MaterialId].FirstOrDefault(l => l.LotNumber == newItem.LotNumber);
            if (targetLot != null && targetLot.BasePrice > 0) newItem.Price = targetLot.BasePrice;
        }
        else if (availableLots.ContainsKey(m.MaterialId) && availableLots[m.MaterialId].Any())
        {
            var bestLot = availableLots[m.MaterialId].OrderBy(l => l.Id).FirstOrDefault();
            if (bestLot != null)
            {
                newItem.LotNumber = bestLot.LotNumber;
                if (bestLot.BasePrice > 0) newItem.Price = bestLot.BasePrice;
            }
        }

        draftItems.Add(newItem);
    }

    private void RemoveDraftItem(DraftItem item)
    {
        draftItems.Remove(item);
    }

    private void OnLotSelected(DraftItem item, string lotNum)
    {
        item.LotNumber = lotNum;
        if (!string.IsNullOrEmpty(lotNum))
        {
            var lot = availableLots[item.MaterialId].FirstOrDefault(l => l.LotNumber == lotNum);
            if(lot != null && lot.BasePrice > 0) item.Price = lot.BasePrice;
        }
    }

    private decimal deliveredValue => deliveries.Sum(d => d.TotalAmount);
    private decimal totalPaid => project?.Payments.Sum(p => p.Amount) ?? 0;
    private decimal totalPaidOnInvoice => project?.Payments.Where(p => p.ShowOnInvoice).Sum(p => p.Amount) ?? 0;
    private decimal balance => deliveredValue - totalPaid;
    private decimal invoiceBalance => deliveredValue - totalPaidOnInvoice;

    private async Task PrepareDelivery()
    {
        if (project == null) return;
        
        var itemsToDeliver = draftItems
            .Where(d => d.Qty != 0)
            .Select(d => {
                var finalQty = d.IsReturn ? -d.Qty : d.Qty;
                return new DeliveryItem 
                { 
                    ProjectMaterialId = d.ProjectMaterialId, 
                    Qty = (double)finalQty,
                    Price = d.Price,
                    Name = d.Name,
                    Unit = d.Unit,
                    LotNumber = d.LotNumber,
                    Subtotal = finalQty * d.Price
                };
            }).ToList();

        if (!itemsToDeliver.Any()) return;

        // KIỂM TRA CHƯA CHỌN LÔ
        foreach (var item in itemsToDeliver)
        {
            if (item.Qty > 0 && string.IsNullOrEmpty(item.LotNumber))
            {
                toastMessage = $"⚠️ Vui lòng chọn **Lô hàng** cho <b>'{item.Name}'</b> để xác định nguồn xuất!";
                showToast = true;
                StateHasChanged();
                _ = Task.Delay(5000).ContinueWith(_ => { showToast = false; InvokeAsync(StateHasChanged); });
                return;
            }
        }
        
        // KIỂM TRA NHANH TRƯỚC KHI XEM HÓA ĐƠN
        var groupedDraft = itemsToDeliver.GroupBy(i => i.ProjectMaterialId);
        foreach (var group in groupedDraft)
        {
            var totalQtyInSlip = group.Sum(i => i.Qty);
            if (totalQtyInSlip <= 0) continue;

            var mat = project.Materials.FirstOrDefault(m => m.Id == group.Key);
            if (mat != null)
            {
                // 1. Kiểm tra hạn mức dự án
                if ((double)totalQtyInSlip > mat.RemainingQty + 0.0001)
                {
                    toastMessage = $"⚠️ <b>'{mat.Name}'</b> vượt hạn mức dự án!\nChỉ còn được xuất tối đa: <b>{mat.RemainingQty.ToString("0.##")}</b>.";
                    showToast = true;
                    StateHasChanged();
                    _ = Task.Delay(5000).ContinueWith(_ => { showToast = false; InvokeAsync(StateHasChanged); });
                    return;
                }

                // 2. Kiểm tra tồn kho thực tế (Kho tổng)
                var mainMat = await WarehouseService.GetMaterialByIdAsync(mat.MaterialId);
                if (mainMat != null)
                {
                    var lotGroups = group.GroupBy(i => i.LotNumber);
                    foreach (var lotGroup in lotGroups)
                    {
                        var lotQty = lotGroup.Sum(i => i.Qty);
                        if (lotQty <= 0) continue;

                        var lot = mainMat.Lots.FirstOrDefault(l => l.LotNumber == lotGroup.Key);
                        if (lot == null || lot.StockQty < lotQty)
                        {
                            toastMessage = $"❌ Lô <b>'{lotGroup.Key}'</b> ({mat.Name}) không đủ hàng!\nChỉ còn: <b>{(lot?.StockQty ?? 0).ToString("0.##")}</b>.";
                            showToast = true;
                            StateHasChanged();
                            _ = Task.Delay(5000).ContinueWith(_ => { showToast = false; InvokeAsync(StateHasChanged); });
                            return;
                        }
                    }
                }
            }
        }

        var itemsTotal = itemsToDeliver.Sum(x => x.Subtotal);
        previewDelivery = new Delivery
        {
            ProjectId = project.Id,
            Timestamp = DateTime.Now,
            Items = itemsToDeliver,
            ItemsTotal = itemsTotal,
            TotalAmount = itemsTotal,
            PreviousBalance = invoiceBalance, 
            GrandTotal = invoiceBalance + itemsTotal 
        };
        showDeliveryReview = true;
    }

    private async Task ConfirmDelivery()
    {
        if (previewDelivery == null || isProcessing || project == null) return;
        isProcessing = true;
        StateHasChanged();

        try 
        {
            // CẬP NHẬT SỐ LƯỢNG TRƯỚC KHI LƯU
            foreach (var item in previewDelivery.Items)
            {
                var mat = project.Materials.FirstOrDefault(m => m.Id == item.ProjectMaterialId);
                if (mat != null)
                {
                    mat.RemainingQty -= (double)item.Qty;
                }
            }

            await WarehouseService.RecordDeliveryAsync(previewDelivery, project.Materials.ToList());
            Nav.NavigateTo($"/invoice/{previewDelivery.Id}");
        }
        finally
        {
            isProcessing = false;
            showDeliveryReview = false;
        }
    }

