                            <div style="padding: 0.75rem; border: 2px solid @(project.InvoiceMode == 1 ? "var(--success)" : "#e2e8f0"); border-radius: 12px; cursor: pointer; background: @(project.InvoiceMode == 1 ? "#f0fdf4" : "white");" @onclick="() => project.InvoiceMode = 1">
