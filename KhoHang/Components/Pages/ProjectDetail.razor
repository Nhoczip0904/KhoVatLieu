@page "/projects/{Id:int}"
@using KhoHang.Models
@using KhoHang.Services
@inject WarehouseService WarehouseService
@inject NavigationManager Nav
@rendermode InteractiveServer

@if (project == null)
{
    <div style="text-align: center; padding: 3rem;">
        <div class="spinner-border text-primary" role="status"></div>
        <p style="margin-top: 1rem; color: var(--text-secondary);">Đang tải dữ liệu dự án...</p>
    </div>
}
else
{
    <div class="fade-in">
        <!-- Header -->
        <div class="header-stack" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; gap: 1rem;">
            <div>
                <button class="btn-outline" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; margin-bottom: 0.75rem;" @onclick='() => Nav.NavigateTo("/projects")'>
                    <i class="bi bi-arrow-left"></i> <span class="d-none d-sm-inline">Quay lại</span>
                </button>
                <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
                    <h1 class="responsive-title" style="font-size: 2rem; margin: 0;">@project.CustomerName</h1>
                    <span class="badge" style="background: @(project.InvoiceMode == 1 ? "#f0fdf4" : "#f0f7ff"); color: @(project.InvoiceMode == 1 ? "#16a34a" : "#2563eb"); font-size: 0.75rem; padding: 0.4rem 0.85rem; border-radius: 8px; border: 1px solid @(project.InvoiceMode == 1 ? "#bcf0da" : "#bfdbfe");">
                        <i class="bi @(project.InvoiceMode == 1 ? "bi-calculator" : "bi-box-seam")"></i> 
                        @(project.InvoiceMode == 1 ? "HĐ Đối soát tài chính" : "HĐ Chỉ tính vật tư")
                    </span>
                    @if (project.IsCompleted)
                    {
                        <span style="background: var(--success); color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700;">HOÀN THÀNH</span>
                    }
                </div>
                <p style="color: var(--text-secondary); margin: 0.25rem 0 0 0; font-size: 0.9rem;"><i class="bi bi-geo-alt"></i> @project.Address | <i class="bi bi-telephone"></i> @project.Phone</p>
            </div>
            @if (!project.IsCompleted)
            {
                <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; justify-content: flex-end;">
                    <button class="btn-primary" style="background: var(--success);" @onclick="ConfirmComplete">
                        <i class="bi bi-check-all"></i> <span class="d-none d-sm-inline">Hoàn thành dự án</span><span class="d-sm-none">Xong</span>
                    </button>
                    <button class="btn-outline text-warning border-warning" @onclick="OpenReturnModal">
                        <i class="bi bi-arrow-return-left"></i> Khách trả hàng
                    </button>
                    <button class="btn-primary" @onclick="() => isPaymentModalOpen = true">
                        <i class="bi bi-cash-stack"></i> Ghi nhận thanh toán
                    </button>
                </div>
            }
        </div>

        <!-- Summary boxes -->
        <div class="grid-responsive-4" style="margin-bottom: 2rem; gap: 0.75rem;">
            <div class="glass-card" style="padding: 0.75rem 1rem;">
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 600;">Tổng giao</div>
                <div style="font-size: 1.25rem; font-weight: 800; color: var(--text-primary); margin-top: 0.25rem;">@deliveredValue.ToString("N0") <span style="font-size: 0.75rem; font-weight: 600;">đ</span></div>
            </div>
            <div class="glass-card" style="padding: 0.75rem 1rem;">
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 600;">Đã trả</div>
                <div style="font-size: 1.25rem; font-weight: 800; color: var(--accent-primary); margin-top: 0.25rem;">@totalPaid.ToString("N0") <span style="font-size: 0.75rem; font-weight: 600;">đ</span></div>
            </div>
            <div class="glass-card" style="padding: 0.75rem 1rem;">
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 600;">@(balance > 0 ? "Còn nợ" : "Dư")</div>
                <div style="font-size: 1.25rem; font-weight: 800; color: @(balance > 0 ? "var(--error)" : "var(--success)"); margin-top: 0.25rem;">@Math.Abs(balance).ToString("N0") <span style="font-size: 0.75rem; font-weight: 600;">đ</span></div>
            </div>
            <div class="glass-card" style="padding: 0.75rem 1rem;">
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 600;">Số lượt</div>
                <div style="font-size: 1.25rem; font-weight: 800; color: var(--text-primary); margin-top: 0.25rem;">@deliveries.Count</div>
            </div>
        </div>

        <!-- Main content: left + right sidebar (Expanded) -->
        <div class="grid-responsive-detail" style="display: grid; grid-template-columns: 1fr 450px; gap: 2rem;">
            <div style="display: flex; flex-direction: column; gap: 2rem;">
                <!-- Material Progress - 2 columns -->
                <div class="glass-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; gap: 0.5rem;">
                        <h3 style="margin: 0; font-size: 1.1rem;">Tiến độ cấp vật tư</h3>
                        @if (!project.IsCompleted)
                        {
                            <button class="btn-outline" style="padding: 0.5rem 0.75rem; font-size: 0.8rem;" @onclick="() => isSelectionModalOpen = true">
                                <i class="bi bi-plus-circle"></i> <span class="d-none d-sm-inline">Thêm</span>
                            </button>
                        }
                    </div>
                    <div class="grid-responsive-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        @foreach (var m in project.Materials)
                        {
                            <div style="background: @(materialToEdit?.Id == m.Id ? "#fff" : "#f8fafc"); padding: 1rem; border-radius: 12px; border: 1px solid @(materialToEdit?.Id == m.Id ? "var(--accent-primary)" : "#e2e8f0"); display: flex; gap: 0.75rem; align-items: flex-start; position: relative; transition: all 0.2s; box-shadow: @(materialToEdit?.Id == m.Id ? "0 10px 20px rgba(67, 97, 238, 0.1)" : "none");">
                                <img src="@(string.IsNullOrEmpty(m.ImageUrl) ? "favicon.png" : m.ImageUrl)" style="width: 48px; height: 48px; border-radius: 8px; object-fit: cover; border: 1px solid #e2e8f0; flex-shrink: 0;" />
                                
                                @if (materialToEdit?.Id == m.Id)
                                {
                                    <div style="flex: 1; min-width: 0;">
                                        <div style="font-weight: 800; font-size: 0.85rem; margin-bottom: 0.75rem; color: var(--accent-primary);">CHỈNH SỬA: @m.Name</div>
                                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                                            <div>
                                                <label style="font-size: 0.65rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Giá chốt (@m.Unit)</label>
                                                <input type="number" @bind="materialToEdit.CustomPrice" class="form-input-modern" style="padding: 0.35rem 0.5rem; font-size: 0.9rem;" />
                                            </div>
                                            <div>
                                                <label style="font-size: 0.65rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Tổng dự kiến</label>
                                                <input type="number" @bind="materialToEdit.TotalQty" class="form-input-modern" style="padding: 0.35rem 0.5rem; font-size: 0.9rem;" />
                                            </div>
                                        </div>
                                        <div style="display: flex; gap: 0.5rem;">
                                            <button class="btn-primary" style="flex: 1; padding: 0.4rem; font-size: 0.75rem;" @onclick="SaveEditedMaterial">
                                                <i class="bi bi-check-lg"></i> Lưu
                                            </button>
                                            <button class="btn-outline" style="flex: 1; padding: 0.4rem; font-size: 0.75rem;" @onclick="() => materialToEdit = null">
                                                Hủy
                                            </button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div style="flex: 1; min-width: 0;">
                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                            <div style="font-weight: 700; padding-right: 2rem;">@m.Name</div>
                                            <div style="font-size: 0.8rem; font-weight: 600; color: @(m.RemainingQty < 0 ? "var(--error)" : "var(--text-primary)");">@m.RemainingQty / @m.TotalQty @m.Unit</div>
                                        </div>
                                        @{ var pct = m.TotalQty > 0 ? Math.Min(100, (100 - (m.RemainingQty * 100 / m.TotalQty))) : 0; }
                                        <div style="height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden; margin-bottom: 0.35rem;">
                                            <div style="height: 100%; background: @(m.RemainingQty < 0 ? "var(--error)" : "var(--accent-primary)"); width: @(Math.Max(0, pct))%"></div>
                                        </div>
                                        <div style="display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--text-secondary);">
                                            <span>Đã giao: @(m.TotalQty - m.RemainingQty)</span>
                                            <span>@m.CustomPrice.ToString("N0") đ/@m.Unit</span>
                                        </div>

                                        @if (!project.IsCompleted)
                                        {
                                            <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem;">
                                                <button class="btn-primary" style="flex: 1; padding: 0.4rem; font-size: 0.75rem; background: var(--accent-primary); color: white; border: none; border-radius: 8px; font-weight: 700; box-shadow: 0 4px 10px rgba(67, 97, 238, 0.2);" 
                                                        @onclick="() => AddExtraRow(m)">
                                                    <i class="bi bi-plus-circle"></i> THÊM VÀO PHIẾU
                                                </button>
                                            </div>
                                            
                                            <button style="position: absolute; top: 0.5rem; right: 0.5rem; background: transparent; border: none; color: #94a3b8; cursor: pointer; padding: 2px;" 
                                                    @onclick="() => StartEditingMaterial(m)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- History Sections -->
                <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
                    <!-- Delivery & Return History -->
                    <div class="glass-card">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                            <h3 style="margin: 0;">Lịch sử giao nhận & Trả hàng</h3>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">Tổng cộng @deliveries.Count() phiếu</div>
                        </div>
                        @if (!deliveries.Any())
                        {
                            <p style="color: var(--text-muted); text-align: center; padding: 1rem;">Chưa có lịch sử giao dịch.</p>
                        }
                        <div style="display: flex; flex-direction: column; gap: 0.75rem; max-height: 450px; overflow-y: auto;" class="custom-scrollbar">
                            @foreach (var d in deliveries.OrderByDescending(x => x.Timestamp))
                            {
                                <div style="background: white; padding: 1rem; border-radius: 12px; border: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; border-left: 4px solid @(d.TotalAmount >= 0 ? "var(--success)" : "var(--error)");">
                                    <div>
                                        @{
                                            bool hExport = d.Items.Any(i => i.Qty > 0);
                                            bool hReturn = d.Items.Any(i => i.Qty < 0);
                                        }
                                        <div style="font-weight: 700; color: var(--text-primary);">
                                            <i class="bi @(hExport && hReturn ? "bi-arrow-left-right" : hReturn ? "bi-arrow-return-left" : "bi-truck")"></i>
                                            @if (hExport && hReturn) { @("Giao & Trả hàng") }
                                            else if (hReturn) { @("Trả hàng") }
                                            else { @("Giao hàng") }
                                            #@d.Id
                                        </div>
                                        <div style="font-size: 0.75rem; color: var(--text-muted);">@d.Timestamp.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 1.5rem;">
                                        <div style="text-align: right;">
                                            <div style="font-weight: 700; color: @(d.TotalAmount >= 0 ? "var(--success)" : "var(--error)");">
                                                @(d.TotalAmount >= 0 ? "" : "-")@Math.Abs(d.TotalAmount).ToString("N0") đ
                                            </div>
                                            <div style="font-size: 0.65rem; color: var(--text-muted);">Chốt nợ: @d.GrandTotal.ToString("N0") đ</div>
                                        </div>
                                        <button class="btn-outline" style="padding: 0.4rem 0.75rem; font-size: 0.75rem;" @onclick='() => Nav.NavigateTo($"/invoice/{d.Id}")'>
                                            <i class="bi bi-printer"></i> Hóa đơn
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Return History -->
                    <div class="glass-card">
                        <h3 style="margin-bottom: 1.5rem; color: var(--warning);">Lịch sử trả hàng</h3>
                        @if (!customerReturns.Any())
                        {
                            <p style="color: var(--text-muted); text-align: center; padding: 1rem;">Chưa có đơn trả hàng nào.</p>
                        }
                        <div style="max-height: 450px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.75rem; padding-right: 0.5rem;" class="custom-scrollbar">
                            @foreach (var r in customerReturns)
                            {
                                <div style="padding: 1rem; border: 1px solid var(--border-color); border-radius: 12px; display: flex; justify-content: space-between; align-items: center; background: white;">
                                    <div>
                                        <div style="font-weight: 700; color: var(--error);">Phiếu trả #@r.Id</div>
                                        <div style="font-size: 0.75rem; color: var(--text-secondary);">@r.Timestamp.ToString("dd/MM/yyyy HH:mm")</div>
                                        <div style="font-size: 0.75rem; color: var(--text-muted);">
                                            @string.Join(", ", r.Items.Select(i => $"{i.Qty} {i.ProjectMaterial?.Unit} {i.ProjectMaterial?.Name}"))
                                        </div>
                                    </div>
                                    <div style="text-align: right;">
                                        <div style="font-weight: 800; color: var(--error);">- @r.TotalAmount.ToString("N0") đ</div>
                                        @{
                                            var dId = deliveries.FirstOrDefault(d => d.TotalAmount < 0 && d.Note != null && d.Note.Contains($"Phiếu trả số: {r.Id}"))?.Id;
                                        }
                                        @if (dId.HasValue)
                                        {
                                            <button class="btn-outline" style="padding: 0.2rem 0.5rem; font-size: 0.65rem; margin-top: 0.25rem;" @onclick='() => Nav.NavigateTo($"/invoice/{dId.Value}")'>
                                                <i class="bi bi-printer"></i> HĐ Trả
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Payment History -->
                    <div class="glass-card">
                        <h3 style="margin-bottom: 1.5rem;">Lịch sử thanh toán</h3>
                        @if (!project.Payments.Any())
                        {
                            <p style="color: var(--text-muted); text-align: center; padding: 1rem;">Chưa có khoản thanh toán nào.</p>
                        }
                        <div style="max-height: 450px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.75rem; padding-right: 0.5rem;" class="custom-scrollbar">
                            @foreach (var p in project.Payments.OrderByDescending(x => x.Timestamp))
                            {
                                <div style="padding: 1rem; border: 1px solid var(--border-color); border-radius: 12px; display: flex; justify-content: space-between; align-items: center; background: white;">
                                    <div>
                                        <div style="font-weight: 600; color: var(--accent-primary);">+ @p.Amount.ToString("N0") đ</div>
                                        <div style="font-size: 0.75rem; color: var(--text-secondary);">@p.Timestamp.ToString("dd/MM/yyyy HH:mm") · @p.Method</div>
                                        @if (!string.IsNullOrEmpty(p.Note))
                                        {
                                            <div style="font-size: 0.75rem; color: var(--text-muted); font-style: italic;">@p.Note</div>
                                        }
                                    </div>
                                    <button style="background: transparent; border: none; color: var(--error); cursor: pointer;" @onclick="() => DeletePayment(p.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right sidebar -->
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                <!-- Quick Delivery Form -->
                @if (!project.IsCompleted)
                {
                    <div class="glass-card" style="border-top: 4px solid var(--accent-primary);">
                        <h3 style="margin-bottom: 1.5rem;">Phiếu xuất kho dự thảo</h3>
                        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                            @if (!draftItems.Any())
                            {
                                <div style="text-align: center; padding: 2rem; border: 2px dashed var(--border-color); border-radius: 16px; color: var(--text-muted);">
                                    <i class="bi bi-cart-plus" style="font-size: 2rem; display: block; margin-bottom: 1rem;"></i>
                                    <p style="font-size: 0.85rem;">Chưa có vật tư nào được chọn.<br/>Vui lòng bấm <b>"THÊM VÀO PHIẾU"</b> từ danh sách bên trái.</p>
                                </div>
                            }
                            @foreach (var item in draftItems)
                            {
                                var mat = project.Materials.FirstOrDefault(m => m.Id == item.ProjectMaterialId);
                                <div style="padding-bottom: 1rem; border-bottom: 1px dashed var(--border-color); position: relative;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                        <label style="font-size: 0.8rem; font-weight: 700;">@item.Name (@item.Unit) · Còn: @(mat?.RemainingQty ?? 0)</label>
                                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                                            <!-- Toggle Switch -->
                                            <div style="display: flex; background: #f1f5f9; padding: 2px; border-radius: 8px; border: 1px solid #e2e8f0;">
                                                <button type="button" @onclick="() => item.IsReturn = false" 
                                                        style="padding: 0.2rem 0.5rem; font-size: 0.65rem; border: none; border-radius: 6px; cursor: pointer; transition: all 0.2s;
                                                               @(item.IsReturn ? "background: transparent; color: #64748b;" : "background: var(--accent-primary); color: white; font-weight: 700;")">
                                                    XUẤT
                                                </button>
                                                <button type="button" @onclick="() => item.IsReturn = true" 
                                                        style="padding: 0.2rem 0.5rem; font-size: 0.65rem; border: none; border-radius: 6px; cursor: pointer; transition: all 0.2s;
                                                               @(!item.IsReturn ? "background: transparent; color: #64748b;" : "background: var(--error); color: white; font-weight: 700;")">
                                                    TRẢ
                                                </button>
                                            </div>

                                            <button class="btn-outline" style="padding: 0.1rem 0.4rem; font-size: 0.65rem;" @onclick="() => { if(mat != null) AddExtraRow(mat); }" title="Thêm dòng cho vật tư này">
                                                <i class="bi bi-plus-circle"></i> Lô khác
                                            </button>
                                            @if (draftItems.Count(x => x.ProjectMaterialId == item.ProjectMaterialId) > 1)
                                            {
                                                <button style="background: transparent; border: none; color: var(--error); padding: 0;" @onclick="() => RemoveDraftItem(item)">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                    
                                    <div style="margin-bottom: 0.75rem;">
                                        <div style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;">Chọn Lô (Tự cập nhật giá)</div>
                                        <select class="form-select-modern" style="padding: 0.4rem; font-size: 0.85rem;" 
                                                value="@item.LotNumber" 
                                                @onchange="@((ChangeEventArgs e) => OnLotSelected(item, e.Value?.ToString() ?? ""))">
                                            <option value="">-- Chọn lô hàng (Nếu có) --</option>
                                            @if (availableLots.ContainsKey(item.MaterialId))
                                            {
                                                foreach (var lot in availableLots[item.MaterialId])
                                                {
                                                    <option value="@lot.LotNumber">Lô: @lot.LotNumber (Tồn: @lot.StockQty @item.Unit · Giá: @lot.BasePrice.ToString("N0"))</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                                        <div>
                                            <div style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;">Số lượng</div>
                                            <input type="number" @bind="item.Qty" 
                                                   style="width: 100%; padding: 0.5rem; font-weight: 600; color: @(item.IsReturn ? "var(--error)" : "inherit")" />
                                        </div>
                                        <div>
                                            <div style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;">Đơn giá</div>
                                            <input type="number" @bind="item.Price" style="width: 100%; padding: 0.5rem; font-weight: 600;" />
                                        </div>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem;">
                                        <button class="btn-outline" style="padding: 0.2rem 0.5rem; font-size: 0.65rem;" @onclick="() => item.Qty = (decimal)(mat?.RemainingQty ?? 0)">MAX</button>
                                        <div style="font-size: 0.85rem; font-weight: 700; color: @(item.IsReturn ? "var(--error)" : "var(--accent-primary)");">
                                            @(item.IsReturn ? "-" : "")@((item.Qty * item.Price).ToString("N0")) đ
                                        </div>
                                    </div>
                                </div>
                            }
                            <button class="btn-primary" style="margin-top: 0.5rem; width: 100%;" @onclick="PrepareDelivery" disabled="@(isProcessing)">
                                <i class="bi bi-eye"></i> Xem trước hóa đơn
                            </button>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- Review Modal -->
    @if (showDeliveryReview && previewDelivery != null)
    {
        <div class="modal-overlay">
            <div class="modal-content" style="max-width: 550px; padding: 0; overflow: hidden; border: none; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
                <!-- Header -->
                <div style="background: var(--accent-primary); color: white; padding: 1.5rem 2rem; display: flex; justify-content: space-between; align-items: center;">
                    <h2 style="margin: 0; font-size: 1.25rem; font-weight: 800; letter-spacing: 0.5px;">XÁC NHẬN XUẤT KHO</h2>
                    <i class="bi bi-file-earmark-check" style="font-size: 1.5rem;"></i>
                </div>

                <div style="padding: 2rem;">
                    <!-- Order Items -->
                    <div style="background: #f8fafc; border-radius: 16px; padding: 1.5rem; border: 1px solid #e2e8f0; margin-bottom: 1.5rem;">
                        <h4 style="margin-top: 0; margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Chi tiết đơn hàng</h4>
                        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                            @foreach (var item in previewDelivery.Items)
                            {
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <div>
                                        <div style="font-weight: 700; color: #1e293b;">@item.Name</div>
                                        @if (!string.IsNullOrEmpty(item.LotNumber) && item.LotNumber != "Mặc định")
                                        {
                                            <div style="font-size: 0.7rem; color: var(--accent-primary); font-weight: 600;">Lô: @item.LotNumber</div>
                                        }
                                        <div style="font-size: 0.75rem; color: var(--text-muted);">Số lượng: @item.Qty @item.Unit x @item.Price.ToString("N0")</div>
                                    </div>
                                    <div style="font-weight: 800; color: #0f172a;">@item.Subtotal.ToString("N0") đ</div>
                                </div>
                            }
                        </div>
                        <hr style="border: none; border-top: 1px dashed #cbd5e1; margin: 1.25rem 0;" />
                        <div style="display: flex; justify-content: space-between; font-size: 1.1rem;">
                            <span style="font-weight: 600; color: var(--text-secondary);">Tổng tiền hàng:</span>
                            <span style="font-weight: 900; color: var(--accent-primary);">@previewDelivery.TotalAmount.ToString("N0") đ</span>
                        </div>
                    </div>

                    <!-- Account Summary -->
                    <div style="padding: 0 0.5rem; margin-bottom: 2rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                            <span style="color: var(--text-secondary); font-weight: 600;">Dư nợ cũ khách hàng:</span>
                            <span style="font-weight: 700; color: @(previewDelivery.PreviousBalance > 0 ? "var(--error)" : "var(--success)");">@previewDelivery.PreviousBalance.ToString("N0") đ</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 1rem; background: @(previewDelivery.GrandTotal > 0 ? "rgba(239, 68, 68, 0.05)" : "rgba(34, 197, 94, 0.05)"); border-radius: 12px; border: 1px solid @(previewDelivery.GrandTotal > 0 ? "rgba(239, 68, 68, 0.1)" : "rgba(34, 197, 94, 0.1)");">
                            <span style="font-weight: 800; font-size: 1.1rem; color: #1e293b;">@(previewDelivery.GrandTotal > 0 ? "TỔNG NỢ SAU XUẤT:" : "SỐ DƯ HIỆN TẠI:")</span>
                            <span style="font-weight: 900; font-size: 1.25rem; color: @(previewDelivery.GrandTotal > 0 ? "var(--error)" : "var(--success)");">@Math.Abs(previewDelivery.GrandTotal).ToString("N0") đ</span>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <button class="btn-outline" style="padding: 1rem; border-radius: 14px; font-weight: 700;" @onclick="() => showDeliveryReview = false">
                            <i class="bi bi-pencil-square"></i> Chỉnh sửa tiếp
                        </button>
                        <button class="btn-primary" style="padding: 1rem; border-radius: 14px; font-weight: 800; box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);" @onclick="ConfirmDelivery">
                            <i class="bi bi-printer"></i> Xác nhận & In
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showCompleteConfirm)
    {
        <div class="modal-overlay">
            <div class="modal-content" style="max-width: 400px; text-align: center;">
                <i class="bi bi-exclamation-triangle" style="font-size: 3rem; color: var(--warning);"></i>
                <h3 style="margin: 1rem 0;">Hoàn thành dự án?</h3>
                <p style="color: var(--text-secondary); margin-bottom: 2rem;">Dự án sẽ được đánh dấu là hoàn thành và không thể xuất kho thêm vật tư. Bạn có chắc chắn?</p>
                <div style="display: flex; gap: 1rem;">
                    <button class="btn-outline" style="flex: 1;" @onclick="() => showCompleteConfirm = false">Hủy</button>
                    <button class="btn-primary" style="flex: 1; background: var(--success);" @onclick="CompleteProject">Xác nhận</button>
                </div>
            </div>
        </div>
    }

    <MaterialSelectionModal @bind-IsOpen="isSelectionModalOpen" 
                            OnMaterialsSelected="OnMaterialsSelected"
                            ExistingMaterialIds="project.Materials.Select(m => m.MaterialId).ToList()" />

    @if (isConfiguringMaterials && selectedMaterialsToConfig.Any())
    {
        <div class="modal-overlay">
            <div class="modal-content" style="max-width: 800px;">
                <h3 style="margin-bottom: 1.5rem;">Thiết lập vật liệu cho dự án</h3>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto; margin-bottom: 1.5rem;">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Vật liệu</th>
                                <th style="width: 150px;">ĐVT</th>
                                <th style="width: 150px;">Giá chốt (đ)</th>
                                <th style="width: 150px;">Tổng số lượng</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pm in selectedMaterialsToConfig)
                            {
                                <tr>
                                    <td style="font-weight: 600;">@pm.Name</td>
                                    <td>@pm.Unit</td>
                                    <td>
                                        <input type="number" @bind="pm.CustomPrice" class="form-input-modern" style="padding: 0.4rem;" />
                                    </td>
                                    <td>
                                        <input type="number" @bind="pm.TotalQty" class="form-input-modern" style="padding: 0.4rem;" />
                                    </td>
                                    <td>
                                        <button class="btn-icon-small" style="color: var(--error);" @onclick="() => selectedMaterialsToConfig.Remove(pm)"><i class="bi bi-x-lg"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                    <button class="btn-outline" @onclick="() => isConfiguringMaterials = false">Hủy</button>
                    <button class="btn-primary" @onclick="SaveConfiguredMaterials">Xác nhận thêm @selectedMaterialsToConfig.Count vật liệu</button>
                </div>
            </div>
        </div>
    }

    <!-- Return Modal -->
    @if (isReturnModalOpen)
    {
        <div class="modal-overlay">
            <div class="modal-content" style="max-width: 800px;">
                <h3 style="margin-bottom: 1.5rem; color: var(--warning);">Ghi nhận khách trả hàng</h3>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto; margin-bottom: 1.5rem;">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Vật liệu đã giao</th>
                                <th>Chọn Lô trả về</th>
                                <th>ĐVT</th>
                                <th>SL trả lại</th>
                                <th>Thành tiền (trừ đi)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in project.Materials)
                            {
                                var delivered = m.TotalQty - m.RemainingQty;
                                if (delivered > 0)
                                {
                                    <tr>
                                        <td>@m.Name</td>
                                        <td>
                                            <select class="form-select-modern" style="padding: 0.4rem; font-size: 0.85rem;" @bind="returnLots[m.Id]">
                                                <option value="">-- Kho chung --</option>
                                                @if (availableLots.ContainsKey(m.MaterialId))
                                                {
                                                    foreach (var lot in availableLots[m.MaterialId])
                                                    {
                                                        <option value="@lot.LotNumber">Lô: @lot.LotNumber (Tồn: @lot.StockQty)</option>
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td>@m.Unit</td>
                                        <td>
                                            <input type="number" @bind="returnItems[m.Id]" @bind:event="oninput" max="@delivered" min="0" class="form-input-modern" style="padding: 0.4rem; width: 100px;" />
                                            <small class="text-muted d-block">Tối đa: @delivered</small>
                                        </td>
                                        <td class="text-danger fw-bold text-end">
                                            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem;">
                                                <input type="number" @bind="returnPrices[m.Id]" @bind:event="oninput" class="form-input-modern" style="padding: 0.4rem; width: 120px; text-align: right; color: var(--error); font-weight: 700;" />
                                                <small class="text-muted" style="font-weight: 400;">
                                                    Tồng: @((((decimal)(returnItems.ContainsKey(m.Id) ? returnItems[m.Id] : 0)) * returnPrices[m.Id]).ToString("N0")) đ
                                                </small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-end">Tổng tiền trừ đi:</th>
                                <th class="text-end text-danger fs-5">@TotalReturnAmount.ToString("N0") đ</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="mb-3">
                    <label>Ghi chú trả hàng</label>
                    <textarea class="form-control" @bind="returnNote" rows="2"></textarea>
                </div>
                <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                    <button class="btn-outline" @onclick="() => isReturnModalOpen = false">Hủy</button>
                    <button class="btn-primary" style="background: var(--warning); color: #000;" @onclick="ConfirmReturn" disabled="@(TotalReturnAmount <= 0)">Xác nhận Trả hàng</button>
                </div>
            </div>
        </div>
    }

    <!-- Payment Modal -->
    @if (isPaymentModalOpen)
    {
        <div class="modal-overlay">
            <div class="modal-content" style="max-width: 450px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3 style="margin: 0; color: var(--success);">Ghi nhận thanh toán</h3>
                    <button style="background: transparent; border: none; font-size: 1.5rem; cursor: pointer;" @onclick="() => isPaymentModalOpen = false">&times;</button>
                </div>
                <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                    <div>
                        <label style="font-size: 0.8rem; font-weight: 700; color: var(--text-secondary); display: block; margin-bottom: 0.5rem;">Số tiền (đ)</label>
                        <input type="number" @bind="paymentAmount" class="form-input-modern" style="font-size: 1.1rem; font-weight: 700;" autofocus />
                    </div>
                    <div>
                        <label style="font-size: 0.8rem; font-weight: 700; color: var(--text-secondary); display: block; margin-bottom: 0.5rem;">Hình thức</label>
                        <select @bind="paymentMethod" class="form-select-modern">
                            <option value="Tiền mặt">Tiền mặt</option>
                            <option value="Chuyển khoản">Chuyển khoản</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                    <div>
                        <label style="font-size: 0.8rem; font-weight: 700; color: var(--text-secondary); display: block; margin-bottom: 0.5rem;">Ghi chú</label>
                        <input type="text" @bind="paymentNote" placeholder="VD: Đợt 1, Cọc..." class="form-input-modern" />
                    </div>
                    @if (project?.InvoiceMode == 0)
                    {
                        <div style="background: #f0f7ff; padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid #bfdbfe; font-size: 0.75rem; color: #2563eb;">
                            <i class="bi bi-info-circle"></i> <b>Chế độ:</b> Thanh toán này chỉ lưu lịch sử, không hiện trên hóa đơn vật tư.
                        </div>
                    }
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem;">
                        <button class="btn-outline" @onclick="() => isPaymentModalOpen = false">Hủy</button>
                        <button class="btn-primary" style="background: var(--success);" @onclick="AddPayment">
                            <i class="bi bi-check-lg"></i> Xác nhận
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    .grid-responsive-detail { display: grid; grid-template-columns: 1fr 450px; gap: 2rem; }
    
    @@media (max-width: 1200px) {
        .grid-responsive-detail { grid-template-columns: 1fr; }
    }

    @@media (max-width: 768px) {
        .responsive-title { font-size: 1.5rem !important; }
        .header-stack { flex-direction: column; align-items: stretch !important; gap: 0.75rem !important; }
        .grid-responsive-2 { grid-template-columns: 1fr !important; }
    }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private Project? project;
    private List<Delivery> deliveries = new();
    private List<CustomerReturn> customerReturns = new();
    // Delivery fields (Dynamic List)
    public class DraftItem
    {
        public int ProjectMaterialId { get; set; }
        public int MaterialId { get; set; }
        public string Name { get; set; } = "";
        public string Unit { get; set; } = "";
        public decimal Qty { get; set; }
        public decimal Price { get; set; }
        public string LotNumber { get; set; } = "";
        public bool IsReturn { get; set; }
    }

    private List<DraftItem> draftItems = new();
    private Dictionary<int, List<MaterialLot>> availableLots = new();
    private bool isProcessing = false;
    private bool isSelectionModalOpen = false;
    private bool showCompleteConfirm = false;
    private bool showDeliveryReview = false;
    private bool isConfiguringMaterials = false;
    private bool isEditingSingleMaterial = false;
    private bool isPaymentModalOpen = false;
    private ProjectMaterial? materialToEdit;
    private List<ProjectMaterial> selectedMaterialsToConfig = new();
    private Delivery? previewDelivery;

    // Payment fields
    private decimal paymentAmount = 0;
    private string paymentMethod = "Tiền mặt";
    private string paymentNote = "";

    // Return fields
    private bool isReturnModalOpen = false;
    private Dictionary<int, double> returnItems = new();
    private Dictionary<int, decimal> returnPrices = new();
    private Dictionary<int, string> returnLots = new();
    private string returnNote = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        project = await WarehouseService.GetProjectByIdAsync(Id);
        if (project != null)
        {
            deliveries = await WarehouseService.GetDeliveriesByProjectIdAsync(Id);
            
            if (draftItems == null) draftItems = new();
            
            // Load available lots for each material
            foreach (var m in project.Materials)
            {
                var lots = await WarehouseService.GetMaterialLotsAsync(m.MaterialId);
                availableLots[m.MaterialId] = lots;
            }

            customerReturns = await WarehouseService.GetCustomerReturnsByProjectIdAsync(Id);
        }
    }

    private void AddExtraRow(ProjectMaterial m)
    {
        var newItem = new DraftItem {
            ProjectMaterialId = m.Id,
            MaterialId = m.MaterialId,
            Name = m.Name,
            Unit = m.Unit,
            Qty = 0,
            Price = m.CustomPrice,
            LotNumber = ""
        };

        // Tự động chọn lô hàng cũ nhất nếu có
        if (availableLots.ContainsKey(m.MaterialId) && availableLots[m.MaterialId].Any())
        {
            var oldestLot = availableLots[m.MaterialId].OrderBy(l => l.Id).FirstOrDefault();
            if (oldestLot != null)
            {
                newItem.LotNumber = oldestLot.LotNumber;
                if (oldestLot.BasePrice > 0) newItem.Price = oldestLot.BasePrice;
            }
        }

        draftItems.Add(newItem);
    }

    private void RemoveDraftItem(DraftItem item)
    {
        draftItems.Remove(item);
    }

    private void OnLotSelected(DraftItem item, string lotNum)
    {
        item.LotNumber = lotNum;
        if (!string.IsNullOrEmpty(lotNum))
        {
            var lot = availableLots[item.MaterialId].FirstOrDefault(l => l.LotNumber == lotNum);
            if (lot != null)
            {
                item.Price = lot.BasePrice;
            }
        }
    }

    private decimal totalValue => project?.Materials.Sum(m => (decimal)m.TotalQty * m.CustomPrice) ?? 0;
    private decimal deliveredValue => deliveries.Sum(d => d.TotalAmount);
    private decimal totalPaid => project?.Payments.Sum(p => p.Amount) ?? 0;
    private decimal totalPaidOnInvoice => project?.Payments.Where(p => p.ShowOnInvoice).Sum(p => p.Amount) ?? 0;
    private decimal balance => deliveredValue - totalPaid;
    private decimal invoiceBalance => deliveredValue - totalPaidOnInvoice;

    private void PrepareDelivery()
    {
        if (project == null) return;
        
        var itemsToDeliver = draftItems
            .Where(d => d.Qty != 0)
            .Select(d => {
                var finalQty = d.IsReturn ? -d.Qty : d.Qty;
                return new DeliveryItem 
                { 
                    ProjectMaterialId = d.ProjectMaterialId, 
                    Qty = (double)finalQty,
                    Price = d.Price,
                    Name = d.Name,
                    Unit = d.Unit,
                    LotNumber = d.LotNumber,
                    Subtotal = finalQty * d.Price
                };
            }).ToList();

        if (!itemsToDeliver.Any()) return;

        var itemsTotal = itemsToDeliver.Sum(x => x.Subtotal);
        previewDelivery = new Delivery
        {
            ProjectId = project.Id,
            Timestamp = DateTime.Now,
            Items = itemsToDeliver,
            ItemsTotal = itemsTotal,
            TotalAmount = itemsTotal,
            PreviousBalance = invoiceBalance, 
            GrandTotal = invoiceBalance + itemsTotal 
        };
        showDeliveryReview = true;
    }

    private async Task ConfirmDelivery()
    {
        if (previewDelivery == null || isProcessing || project == null) return;
        isProcessing = true;
        try 
        {
            // CẬP NHẬT SỐ LƯỢNG TRƯỚC KHI LƯU
            foreach (var item in previewDelivery.Items)
            {
                var mat = project.Materials.FirstOrDefault(m => m.Id == item.ProjectMaterialId);
                if (mat != null)
                {
                    mat.RemainingQty -= (double)item.Qty;
                }
            }

            await WarehouseService.RecordDeliveryAsync(previewDelivery, project.Materials.ToList());
            Nav.NavigateTo($"/invoice/{previewDelivery.Id}");
        }
        finally
        {
            isProcessing = false;
            showDeliveryReview = false;
        }
    }

    private async Task AddPayment()
    {
        if (project == null || paymentAmount <= 0) return;

        var payment = new Payment
        {
            ProjectId = project.Id,
            Amount = paymentAmount,
            Method = paymentMethod,
            Note = paymentNote,
            Timestamp = DateTime.Now,
            ShowOnInvoice = project.InvoiceMode == 1 // Tự động dựa theo thiết lập dự án
        };

        await WarehouseService.AddPaymentAsync(payment);
        paymentAmount = 0;
        paymentNote = "";
        isPaymentModalOpen = false;
        await LoadData();
    }

    private async Task DeletePayment(int id)
    {
        await WarehouseService.DeletePaymentAsync(id);
        await LoadData();
    }

    private void OnMaterialsSelected(List<Material> materials)
    {
        if (!materials.Any()) return;

        selectedMaterialsToConfig = materials.Select(m => new ProjectMaterial
        {
            MaterialId = m.Id,
            Name = m.Name,
            Unit = m.Unit,
            CustomPrice = m.Lots.OrderBy(l => l.Id).FirstOrDefault()?.BasePrice ?? 0,
            TotalQty = 0,
            RemainingQty = 0,
            ImageUrl = m.ImageUrl,
            ProjectId = project?.Id ?? 0
        }).ToList();

        isConfiguringMaterials = true;
    }

    private async Task SaveConfiguredMaterials()
    {
        if (project == null || !selectedMaterialsToConfig.Any()) return;

        foreach (var pm in selectedMaterialsToConfig)
        {
            pm.RemainingQty = pm.TotalQty; // Initial state
            await WarehouseService.AddProjectMaterialAsync(pm);
        }

        isConfiguringMaterials = false;
        selectedMaterialsToConfig.Clear();
        await LoadData();
    }

    private void StartEditingMaterial(ProjectMaterial m)
    {
        materialToEdit = new ProjectMaterial
        {
            Id = m.Id,
            MaterialId = m.MaterialId,
            ProjectId = m.ProjectId,
            Name = m.Name,
            Unit = m.Unit,
            CustomPrice = m.CustomPrice,
            TotalQty = m.TotalQty,
            RemainingQty = m.RemainingQty,
            ImageUrl = m.ImageUrl
        };
    }

    private async Task SaveEditedMaterial()
    {
        if (materialToEdit == null) return;
        
        // Recalculate remaining quantity based on new total and already delivered amount
        var original = project?.Materials.FirstOrDefault(m => m.Id == materialToEdit.Id);
        if (original != null)
        {
            var delivered = original.TotalQty - original.RemainingQty;
            materialToEdit.RemainingQty = materialToEdit.TotalQty - delivered;
        }

        await WarehouseService.UpdateProjectMaterialAsync(materialToEdit);
        isEditingSingleMaterial = false;
        await LoadData();
    }

    private void ConfirmComplete() => showCompleteConfirm = true;

    private async Task CompleteProject()
    {
        if (project == null) return;
        await WarehouseService.CompleteProjectAsync(project.Id);
        showCompleteConfirm = false;
        await LoadData();
    }

    private void OpenReturnModal()
    {
        if (project == null) return;
        returnItems.Clear();
        foreach (var m in project.Materials)
        {
            var delivered = m.TotalQty - m.RemainingQty;
            if (delivered > 0)
            {
                returnItems[m.Id] = 0;
                returnPrices[m.Id] = m.CustomPrice;
                
                // Mặc định chọn lô "Mặc định" nếu có, hoặc lô đầu tiên
                var defaultLot = "";
                if (availableLots.ContainsKey(m.MaterialId) && availableLots[m.MaterialId].Any())
                {
                    var macDinh = availableLots[m.MaterialId].FirstOrDefault(l => l.LotNumber == "Mặc định");
                    defaultLot = macDinh?.LotNumber ?? availableLots[m.MaterialId].First().LotNumber;
                }
                returnLots[m.Id] = defaultLot;
            }
        }
        returnNote = "";
        isReturnModalOpen = true;
    }

    private decimal TotalReturnAmount => project?.Materials
        .Where(m => returnItems.ContainsKey(m.Id))
        .Sum(m => (decimal)returnItems[m.Id] * (returnPrices.ContainsKey(m.Id) ? returnPrices[m.Id] : m.CustomPrice)) ?? 0;

    private async Task ConfirmReturn()
    {
        if (project == null || TotalReturnAmount <= 0) return;

        var items = new List<CustomerReturnItem>();
        foreach (var kvp in returnItems.Where(k => k.Value > 0))
        {
            var mat = project.Materials.First(m => m.Id == kvp.Key);
            var price = returnPrices.ContainsKey(mat.Id) ? returnPrices[mat.Id] : mat.CustomPrice;
            var lotNum = returnLots.ContainsKey(mat.Id) ? returnLots[mat.Id] : "";
            items.Add(new CustomerReturnItem
            {
                ProjectMaterialId = mat.Id,
                Qty = kvp.Value,
                Price = price,
                Subtotal = (decimal)kvp.Value * price
            });
            // Update remaining qty (increase it because they returned)
            mat.RemainingQty += kvp.Value;
            await WarehouseService.UpdateProjectMaterialAsync(mat);
        }

        var cr = new CustomerReturn
        {
            ProjectId = project.Id,
            Timestamp = DateTime.Now,
            TotalAmount = TotalReturnAmount,
            Note = returnNote,
            Items = items
        };

        var deliveryId = await WarehouseService.AddCustomerReturnAsync(cr);
        isReturnModalOpen = false;
        Nav.NavigateTo($"/invoice/{deliveryId}");
    }
}
