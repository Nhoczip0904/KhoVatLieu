                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                            <div style="padding: 0.75rem; border: 2px solid @(project.InvoiceMode == 0 ? "var(--accent-primary)" : "#e2e8f0"); border-radius: 12px; cursor: pointer; background: @(project.InvoiceMode == 0 ? "#f0f7ff" : "white");" @onclick="() => project.InvoiceMode = 0">
