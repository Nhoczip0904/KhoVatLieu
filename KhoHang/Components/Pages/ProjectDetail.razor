    private async Task OnMaterialsSelected(List<Material> materials)
    {
        if (!materials.Any()) return;

        selectedMaterialsToConfig = materials.Select(m => new ProjectMaterial
        {
            MaterialId = m.Id,
            Name = m.Name,
            Unit = m.Unit,
            CustomPrice = m.Lots.OrderBy(l => l.Id).FirstOrDefault()?.BasePrice ?? 0,
            TotalQty = 0,
            RemainingQty = 0,
            ImageUrl = m.ImageUrl,
            ProjectId = project?.Id ?? 0
        }).ToList();

        foreach (var pm in selectedMaterialsToConfig)
        {
            if (!availableLots.ContainsKey(pm.MaterialId))
            {
                availableLots[pm.MaterialId] = await WarehouseService.GetMaterialLotsAsync(pm.MaterialId);
            }
            pm.TargetLotNumber = availableLots[pm.MaterialId].OrderBy(l => l.Id).FirstOrDefault()?.LotNumber ?? "";
        }

        isConfiguringMaterials = true;
    }

    private void DuplicateConfigMaterial(ProjectMaterial pm)
    {
        var lots = availableLots.ContainsKey(pm.MaterialId) ? availableLots[pm.MaterialId] : new List<MaterialLot>();
        
        // Tìm các lô đã dùng cho vật tư này (bao gồm cả trong dự án cũ và trong list đang config)
        var usedInProject = project.Materials
            .Where(existing => existing.MaterialId == pm.MaterialId)
            .Select(existing => existing.TargetLotNumber);
            
        var usedInConfig = selectedMaterialsToConfig
            .Where(existing => existing.MaterialId == pm.MaterialId)
            .Select(existing => existing.TargetLotNumber);
            
        var usedLots = usedInProject.Concat(usedInConfig).Distinct().ToList();
        
        var nextLot = lots.FirstOrDefault(l => !usedLots.Contains(l.LotNumber)) ?? lots.FirstOrDefault();

        var index = selectedMaterialsToConfig.IndexOf(pm);
        selectedMaterialsToConfig.Insert(index + 1, new ProjectMaterial
        {
            MaterialId = pm.MaterialId,
            Name = pm.Name,
            Unit = pm.Unit,
            CustomPrice = pm.CustomPrice,
            TotalQty = pm.TotalQty,
            RemainingQty = pm.RemainingQty,
            ImageUrl = pm.ImageUrl,
            ProjectId = pm.ProjectId,
            TargetLotNumber = nextLot?.LotNumber ?? ""
        });
    }

    private async Task SaveConfiguredMaterials()
    {
        if (project == null || !selectedMaterialsToConfig.Any()) return;

        foreach (var pm in selectedMaterialsToConfig)
        {
            pm.RemainingQty = pm.TotalQty;
            await WarehouseService.AddProjectMaterialAsync(pm);
        }

        isConfiguringMaterials = false;
        selectedMaterialsToConfig.Clear();
        await LoadData();
    }

    private async Task StartEditingMaterial(ProjectMaterial m)
    {
        materialToEdit = new ProjectMaterial
        {
            Id = m.Id,
            MaterialId = m.MaterialId,
            ProjectId = m.ProjectId,
            Name = m.Name,
            Unit = m.Unit,
            CustomPrice = m.CustomPrice,
            TotalQty = m.TotalQty,
            RemainingQty = m.RemainingQty,
            ImageUrl = m.ImageUrl,
            TargetLotNumber = m.TargetLotNumber
        };
        await CheckPromisedAvailability();
    }

    private async Task SaveEditedMaterial()
    {
        if (materialToEdit == null) return;
        
        // Recalculate remaining quantity based on new total and already delivered amount
        var original = project?.Materials.FirstOrDefault(m => m.Id == materialToEdit.Id);
        if (original != null)
        {
            var delivered = original.TotalQty - original.RemainingQty;
            materialToEdit.RemainingQty = materialToEdit.TotalQty - delivered;
        }

        await WarehouseService.UpdateProjectMaterialAsync(materialToEdit);
        materialToEdit = null;
        promisedWarning = null;
        await LoadData();
    }

    private async Task CheckPromisedAvailability()
    {
        if (materialToEdit == null) return;
        
        var matId = materialToEdit.MaterialId;
        var lotNum = materialToEdit.TargetLotNumber;
        
        // Lấy số lượng đã hứa ở các dự án KHÁC
        var promisedOther = await WarehouseService.GetTotalPromisedQtyAsync(matId, lotNum);
        
        // Trừ đi số lượng hiện tại của chính dự án này trong kết quả trên (nếu đang sửa)
        var currentInProject = project?.Materials.FirstOrDefault(m => m.Id == materialToEdit.Id);
        if (currentInProject != null)
        {
            // Nếu không chọn lô, hoặc lô hiện tại trùng với lô đang tính
            if (string.IsNullOrEmpty(lotNum) || currentInProject.TargetLotNumber == lotNum)
            {
                promisedOther -= currentInProject.RemainingQty;
            }
        }
        
        // Tổng hứa = Đã hứa các dự án khác + Dự kiến mới của dự án này
        var totalPromised = promisedOther + materialToEdit.TotalQty;
        
        // Lấy tồn kho thực tế
        double actualStock = 0;
        var mainMat = await WarehouseService.GetMaterialByIdAsync(matId);
        if (mainMat != null)
        {
            if (string.IsNullOrEmpty(lotNum))
            {
                actualStock = mainMat.StockQty;
            }
            else
            {
                var lot = mainMat.Lots.FirstOrDefault(l => l.LotNumber == lotNum);
                actualStock = lot?.StockQty ?? 0;
            }
        }
        
        if (totalPromised > actualStock + 0.0001)
        {
            var diff = totalPromised - actualStock;
            promisedWarning = $"⚠️ Kho {(string.IsNullOrEmpty(lotNum) ? "tổng" : $"lô '{lotNum}'")} chỉ còn {actualStock.ToString("0.##")}. Tổng yêu cầu các dự án ({totalPromised.ToString("0.##")}) sẽ vượt {diff.ToString("0.##")}!";
        }
        else
        {
            promisedWarning = null;
        }
        StateHasChanged();
    }

    private void ConfirmComplete() => showCompleteConfirm = true;

    private async Task CompleteProject()
    {
        if (project == null) return;
        await WarehouseService.CompleteProjectAsync(project.Id);
