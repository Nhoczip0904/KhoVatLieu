    private void OpenReturnModal()
    {
        if (project == null) return;
        returnItems.Clear();
        foreach (var m in project.Materials)
        {
            var delivered = m.TotalQty - m.RemainingQty;
            if (delivered > 0)
            {
                returnItems[m.Id] = 0;
                returnPrices[m.Id] = m.CustomPrice;
                
                // Mặc định chọn lô "Mặc định" nếu có, hoặc lô đầu tiên
                var defaultLot = "";
                if (availableLots.ContainsKey(m.MaterialId) && availableLots[m.MaterialId].Any())
                {
                    var macDinh = availableLots[m.MaterialId].FirstOrDefault(l => l.LotNumber == "Mặc định");
                    defaultLot = macDinh?.LotNumber ?? availableLots[m.MaterialId].First().LotNumber;
                }
                returnLots[m.Id] = defaultLot;
            }
        }
        returnNote = "";
        isReturnModalOpen = true;
    }

    private decimal TotalReturnAmount => project?.Materials
        .Where(m => returnItems.ContainsKey(m.Id))
        .Sum(m => (decimal)returnItems[m.Id] * (returnPrices.ContainsKey(m.Id) ? returnPrices[m.Id] : m.CustomPrice)) ?? 0;

    private async Task ConfirmReturn()
    {
        if (project == null || TotalReturnAmount <= 0) return;

        var items = new List<CustomerReturnItem>();
        foreach (var kvp in returnItems.Where(k => k.Value > 0))
        {
            var mat = project.Materials.First(m => m.Id == kvp.Key);
            var price = returnPrices.ContainsKey(mat.Id) ? returnPrices[mat.Id] : mat.CustomPrice;
            var lotNum = returnLots.ContainsKey(mat.Id) ? returnLots[mat.Id] : "";
            items.Add(new CustomerReturnItem
            {
                ProjectMaterialId = mat.Id,
                Qty = kvp.Value,
                Price = price,
                Subtotal = (decimal)kvp.Value * price
            });
            // Update remaining qty (increase it because they returned)
            mat.RemainingQty += kvp.Value;
            await WarehouseService.UpdateProjectMaterialAsync(mat);
        }

        var cr = new CustomerReturn
        {
            ProjectId = project.Id,
            Timestamp = DateTime.Now,
            TotalAmount = TotalReturnAmount,
            Note = returnNote,
            Items = items
        };

        var deliveryId = await WarehouseService.AddCustomerReturnAsync(cr);
        isReturnModalOpen = false;
        Nav.NavigateTo($"/invoice/{deliveryId}");
    }
    private Dictionary<int, string> configWarnings = new();
    private bool isCompactView = true; // Default to compact for efficiency
    private bool isMainCompactView = false; // Main list defaults to cards

    private async Task CheckConfigAvailability(ProjectMaterial pm)
    {
        var totalPromised = await WarehouseService.GetTotalPromisedQtyAsync(pm.MaterialId, pm.TargetLotNumber);
        
        var mainMat = await WarehouseService.GetMaterialByIdAsync(pm.MaterialId);
        double actualStock = 0;
        if (mainMat != null)
        {
            var lot = mainMat.Lots.FirstOrDefault(l => l.LotNumber == pm.TargetLotNumber);
            actualStock = lot?.StockQty ?? 0;
        }

        var totalNeeded = totalPromised + pm.TotalQty;
        if (totalNeeded > actualStock + 0.0001)
        {
            configWarnings[pm.MaterialId] = $"Với số lượng {pm.TotalQty.ToString("0.##")} này, Lô '{pm.TargetLotNumber}' sẽ thiếu {(totalNeeded - actualStock).ToString("0.##")} so với tổng nhu cầu các dự án.";
        }
        else
        {
            configWarnings.Remove(pm.MaterialId);
        }
        StateHasChanged();
    }
