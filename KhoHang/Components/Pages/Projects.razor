@page "/projects"
@attribute [Authorize]
@using KhoHang.Models
@using KhoHang.Services
@inject WarehouseService WarehouseService
@inject AiActionBridgeService AiActionBridge
@inject NavigationManager Nav
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Quản lý Dự án & Khách hàng</PageTitle>

<div class="fade-in">
    <div class="header-stack" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; gap: 1rem;">
        <div>
            <h1 class="responsive-title" style="font-size: 2.2rem; font-weight: 800; font-family: 'Outfit'; margin: 0; color: #0f172a;">Dự án & Xuất kho</h1>
        </div>
        <button class="btn-primary" @onclick="() => isAdding = true">
            <i class="bi bi-plus-lg"></i> <span class="d-none d-sm-inline">Dự án mới</span><span class="d-sm-none">Thêm</span>
        </button>
    </div>

    <!-- Tab Navigation -->
    <div class="scroll-x-auto" style="display: flex; gap: 2rem; border-bottom: 2px solid var(--border-color); margin-bottom: 2.5rem;">
        <button style="background: transparent; border: none; padding: 1rem 0; border-bottom: 3px solid @(!showCompleted ? "var(--accent-primary)" : "transparent"); color: @(!showCompleted ? "var(--accent-primary)" : "var(--text-secondary)"); font-weight: 700; cursor: pointer; transition: all 0.2s; white-space: nowrap;" @onclick="() => SetTab(false)">Đang thực hiện (@activeCount)</button>
        <button style="background: transparent; border: none; padding: 1rem 0; border-bottom: 3px solid @(showCompleted ? "var(--accent-primary)" : "transparent"); color: @(showCompleted ? "var(--accent-primary)" : "var(--text-secondary)"); font-weight: 700; cursor: pointer; transition: all 0.2s; white-space: nowrap;" @onclick="() => SetTab(true)">Đã hoàn thành (@completedCount)</button>
    </div>

    <div class="search-stack" style="display: flex; gap: 1rem; margin-bottom: 2.5rem; align-items: center;">
        <div class="search-container" style="flex: 1; margin-bottom: 0;">
            <i class="bi bi-search" style="font-size: 1.2rem;"></i>
            <input type="text" placeholder="Tìm tên khách hàng, SĐT..." @bind="searchText" @bind:event="oninput" style="padding: 1rem 3rem; font-size: 1rem; border-radius: 16px;" />
        </div>
        <div style="color: var(--text-secondary); font-weight: 600; font-size: 0.9rem;" class="d-none d-sm-block">
            @filteredProjects.Count kết quả
        </div>
    </div>

    @if (isAdding)
    {
        <div class="glass-card" style="margin-bottom: 3rem; border: 2px solid #e0e7ff; max-width: 900px; margin-left: auto; margin-right: auto; padding: 2.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <h2 style="font-size: 1.5rem; margin: 0; font-family: 'Outfit'; font-weight: 800;">Thiết lập dự án mới</h2>
                <button style="background: transparent; border: none; color: var(--text-secondary);" @onclick="() => isAdding = false"><i class="bi bi-x-lg"></i></button>
            </div>
            
            <div class="responsive-grid-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
                <div style="grid-column: 1 / -1;">
                    <label style="font-size: 0.75rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Chọn từ danh bạ khách hàng</label>
                    <select @onchange="OnCustomerSelected" class="form-select-modern">
                        <option value="">-- Tạo mới hoặc chọn khách lẻ --</option>
                        @foreach (var c in customers) { <option value="@c.Id">@c.Name (@c.Phone)</option> }
                    </select>
                </div>
                <div class="form-col-sm">
                    <label style="font-size: 0.75rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Tên khách hàng</label>
                    <input @bind="newProject.CustomerName" placeholder="VD: Anh Nam - Q1" style="width: 100%;" />
                </div>
                <div class="form-col-sm">
                    <label style="font-size: 0.75rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Số điện thoại</label>
                    <input @bind="newProject.Phone" placeholder="09xx..." style="width: 100%;" />
                </div>
                <div style="grid-column: 1 / -1;">
                    <label style="font-size: 0.75rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Địa chỉ giao hàng / Công trình</label>
                    <input @bind="newProject.Address" style="width: 100%;" />
                </div>
                <!-- Invoice Mode Selection -->
                <div style="grid-column: 1 / -1; margin-top: 0.5rem;">
                    <label style="font-size: 0.75rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; display: block; margin-bottom: 0.75rem;">Chế độ hóa đơn cho kho này</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div style="padding: 1rem; border: 2px solid @(newProject.InvoiceMode == 0 ? "var(--accent-primary)" : "#e2e8f0"); border-radius: 12px; cursor: pointer; background: @(newProject.InvoiceMode == 0 ? "#f0f7ff" : "white"); transition: all 0.2s;" @onclick="() => newProject.InvoiceMode = 0">
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                <i class="bi bi-box-seam" style="font-size: 1.5rem; color: @(newProject.InvoiceMode == 0 ? "var(--accent-primary)" : "#94a3b8");"></i>
                                <div>
                                    <div style="font-weight: 700; font-size: 0.9rem;">HĐ không tính cọc</div>
                                    <div style="font-size: 0.7rem; color: #64748b;">Hóa đơn chỉ hiện nợ hàng hóa, không hiện thanh toán tiền cọc.</div>
                                </div>
                            </div>
                        </div>
                        <div style="padding: 1rem; border: 2px solid @(newProject.InvoiceMode == 1 ? "var(--success)" : "#e2e8f0"); border-radius: 12px; cursor: pointer; background: @(newProject.InvoiceMode == 1 ? "#f0fdf4" : "white"); transition: all 0.2s;" @onclick="() => newProject.InvoiceMode = 1">
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                <i class="bi bi-calculator" style="font-size: 1.5rem; color: @(newProject.InvoiceMode == 1 ? "var(--success)" : "#94a3b8");"></i>
                                <div>
                                    <div style="font-weight: 700; font-size: 0.9rem;">HĐ tính cọc</div>
                                    <div style="font-size: 0.7rem; color: #64748b;">Hóa đơn bao gồm cả tiền cọc, thanh toán đợt...</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div style="border-top: 1px solid var(--border-color); padding-top: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3 style="font-size: 1.25rem; margin: 0; font-family: 'Outfit'; font-weight: 700;">Danh sách vật tư & Giá chốt</h3>
                    <button type="button" class="btn-outline" @onclick="() => isSelectionModalOpen = true">
                        <i class="bi bi-plus-circle"></i> Chọn vật liệu
                    </button>
                </div>

                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    @foreach (var sm in selectedMaterials)
                    {
                        <div style="display: flex; flex-direction: column; gap: 0.5rem; background: #f8fafc; padding: 1.25rem; border-radius: 16px; border: 1px solid #e2e8f0;">
                            <div style="display: grid; grid-template-columns: 2fr 1.5fr 1fr 1fr auto; gap: 1rem; align-items: center;">
                                <div>
                                    <div style="font-weight: 700; color: #0f172a;">@sm.Name</div>
                                    <div style="font-size: 0.8rem; color: var(--text-secondary);">ĐVT: @sm.Unit</div>
                                </div>
                                <div>
                                    <label style="font-size: 0.65rem; color: #64748b; font-weight: 800; text-transform: uppercase;">Lô dự kiến</label>
                                    <select @bind="sm.TargetLotNumber" class="form-select-modern" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                        @if (availableLots.ContainsKey(sm.MaterialId))
                                        {
                                            var usedLots = selectedMaterials
                                                .Where(existing => existing != sm && existing.MaterialId == sm.MaterialId)
                                                .Select(existing => existing.TargetLotNumber)
                                                .ToList();

                                            foreach (var lot in availableLots[sm.MaterialId].Where(l => !usedLots.Contains(l.LotNumber)))
                                            {
                                                <option value="@lot.LotNumber">Lô: @lot.LotNumber (Tồn: @lot.StockQty @sm.Unit)</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label style="font-size: 0.65rem; color: #64748b; font-weight: 800; text-transform: uppercase;">Giá bán dự án</label>
                                    <input type="number" @bind="sm.CustomPrice" style="width: 100%; padding: 0.5rem;" />
                                </div>
                                <div>
                                    <label style="font-size: 0.65rem; color: #64748b; font-weight: 800; text-transform: uppercase;">Tổng SL</label>
                                    <input type="number" @bind="sm.TotalQty" @bind:event="oninput" @onkeyup="() => CheckPromisedAvailability(sm)" style="width: 100%; padding: 0.5rem;" />
                                </div>
                                <div style="display: flex; gap: 8px; align-items: center;">
                                    <button class="btn-icon-small" style="color: var(--accent-primary);" @onclick="() => DuplicateMaterial(sm)" title="Nhân bản dòng này">
                                        <i class="bi bi-copy"></i>
                                    </button>
                                    <button style="background: transparent; border: none; color: #ef4444; cursor: pointer; font-size: 1.25rem;" @onclick="() => RemoveMaterial(sm)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>

                            @if (promisedWarnings.ContainsKey(sm.MaterialId) && promisedWarnings[sm.MaterialId] != null)
                            {
                                <div style="font-size: 0.7rem; color: #b91c1c; font-weight: 600; background: #fff1f2; padding: 0.5rem 0.75rem; border-radius: 8px; border: 1px solid #fecaca; line-height: 1.4;">
                                    <i class="bi bi-exclamation-triangle-fill"></i> @promisedWarnings[sm.MaterialId]
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 3rem;">
                <button class="btn-outline" style="padding: 0.75rem 2rem;" @onclick="() => isAdding = false">Hủy bỏ</button>
                <button class="btn-primary" style="padding: 0.75rem 2rem;" @onclick="SaveProject">Lưu & Khởi tạo dự án</button>
            </div>
        </div>
    }

    <div class="grid-responsive-3">
        @foreach (var p in PaginatedProjects)
        {
            <div class="glass-card" style="cursor: pointer; transition: all 0.2s; border-left: 6px solid @(p.IsCompleted ? "#94a3b8" : "#4f46e5"); position: relative;" @onclick='() => Nav.NavigateTo($"/projects/{p.Id}")'>
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
                    <div style="background: @(p.IsCompleted ? "#f1f5f9" : "#eef2ff"); color: @(p.IsCompleted ? "#64748b" : "#4f46e5"); padding: 1rem; border-radius: 16px;">
                        <i class="bi @(p.IsCompleted ? "bi-check-circle" : "bi-briefcase")" style="font-size: 1.75rem;"></i>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 0.85rem; color: var(--text-secondary); font-weight: 700;">@p.CreatedAt.ToString("dd/MM/yyyy")</div>
                        @if (p.IsCompleted) { <span style="background: #f1f5f9; color: #64748b; font-size: 0.7rem; font-weight: 800; padding: 0.25rem 0.5rem; border-radius: 6px; margin-top: 0.5rem; display: inline-block;">ĐÃ ĐÓNG KHO</span> }
                    </div>
                </div>
                
                <h3 style="margin: 0 0 0.5rem 0; font-size: 1.75rem; font-family: 'Outfit'; font-weight: 800; color: #0f172a;">@p.CustomerName</h3>
                <div style="display: flex; flex-direction: column; gap: 0.5rem; color: var(--text-secondary); font-size: 1rem; margin-bottom: 1.5rem;">
                    <span><i class="bi bi-phone"></i> @p.Phone</span>
                    <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><i class="bi bi-geo-alt"></i> @p.Address</span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
                    <span style="font-size: 0.9rem; font-weight: 600; color: var(--text-secondary);">@p.Materials.Count vật tư được chốt</span>
                    <span style="color: var(--accent-primary); font-weight: 700; font-size: 0.95rem;">Chi tiết <i class="bi bi-chevron-right"></i></span>
                </div>
            </div>
        }
    </div>

    @if (TotalPages > 1)
    {
        <div style="margin-top: 4rem; display: flex; justify-content: center; align-items: center; gap: 2rem; background: white; padding: 1.5rem; border-radius: 20px; border: 1px solid var(--border-color); max-width: 500px; margin-left: auto; margin-right: auto;">
            <button class="btn-outline" style="width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center;" disabled="@(currentPage == 1)" @onclick="() => currentPage--">
                <i class="bi bi-chevron-left"></i>
            </button>
            <div style="text-align: center;">
                <span style="font-weight: 800; font-size: 1.1rem; color: #0f172a;">Trang @currentPage</span>
                <div style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;">Tổng cộng @TotalPages trang</div>
            </div>
            <button class="btn-outline" style="width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center;" disabled="@(currentPage >= TotalPages)" @onclick="() => currentPage++">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    }
</div>

<style>
    @@media (max-width: 576px) {
        .responsive-title { font-size: 1.3rem !important; }
        .header-stack { flex-direction: column; align-items: stretch !important; gap: 0.5rem !important; }
        .search-stack { flex-direction: column; align-items: stretch !important; }
        .form-col-sm { grid-column: 1 / -1; }
        .responsive-grid-form { gap: 0.75rem !important; }
    }
    @@media (max-width: 768px) {
        .responsive-title { font-size: 1.75rem !important; }
        .header-stack { flex-direction: column; align-items: flex-start !important; }
        .search-stack { flex-direction: column; align-items: stretch !important; }
        .form-col-sm { grid-column: 1 / -1; }
        .responsive-grid-form { gap: 0.75rem !important; }
    }
</style>

<MaterialSelectionModal @bind-IsOpen="isSelectionModalOpen" 
                        OnMaterialsSelected="OnMaterialsSelected" 
                        ExistingMaterialIds="new List<int>()"
                        AllowZeroStock="false" />

@code {
    private List<Project> allProjects = new();
    private List<Customer> customers = new();
    private bool isAdding = false;
    private Project newProject = new();
    private List<ProjectMaterial> selectedMaterials = new();
    private Dictionary<int, List<MaterialLot>> availableLots = new();
    private Dictionary<int, string?> promisedWarnings = new();
    private bool isSelectionModalOpen = false;
    
    private bool showCompleted = false;
    private string _searchText = "";
    private string searchText {
        get => _searchText;
        set {
            if (_searchText != value) {
                _searchText = value;
                currentPage = 1;
            }
        }
    }
    private int currentPage = 1;
    private int pageSize = 6;

    private int activeCount => allProjects.Count(p => !p.IsCompleted);
    private int completedCount => allProjects.Count(p => p.IsCompleted);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        customers = await WarehouseService.GetCustomersAsync();
        AiActionBridge.OnActionTriggered += HandleAiAction;
    }

    public void Dispose()
    {
        AiActionBridge.OnActionTriggered -= HandleAiAction;
    }

    private async void HandleAiAction(AiActionMessage msg)
    {
        if (msg.ActionType == "create_project")
        {
            // 1. Mở form thiết lập dự án mới
            isAdding = true;

            // 2. Thiết lập thông tin dự án/khách hàng
            newProject = new Project
            {
                CustomerName = msg.Data.GetValueOrDefault("customerName", ""),
                Phone = msg.Data.GetValueOrDefault("phone"),
                Address = msg.Data.GetValueOrDefault("address"),
                InvoiceMode = 1 // HĐ tính cọc mặc định
            };

            // 3. Khớp vật tư thông minh từ danh sách AI gửi về
            selectedMaterials.Clear();
            promisedWarnings.Clear();
            var allDbMaterials = await WarehouseService.GetMasterMaterialsAsync();

            foreach (var aiMat in msg.Materials)
            {
                // So khớp tìm kiếm sản phẩm gần giống nhất dựa vào tên
                var matchedMat = allDbMaterials
                    .Where(m => !m.IsDeleted)
                    .OrderByDescending(m => CalculateSimilarity(m.Name, aiMat.Name))
                    .FirstOrDefault();

                if (matchedMat != null)
                {
                    // Kiểm tra xem độ tương đồng có đủ tin cậy không (tên chứa từ khóa của nhau hoặc tương đồng > 35%)
                    bool isMatch = matchedMat.Name.Contains(aiMat.Name, StringComparison.OrdinalIgnoreCase) || 
                                   aiMat.Name.Contains(matchedMat.Name, StringComparison.OrdinalIgnoreCase) || 
                                   CalculateSimilarity(matchedMat.Name, aiMat.Name) > 0.35;

                    if (isMatch)
                    {
                        var lots = await WarehouseService.GetMaterialLotsAsync(matchedMat.Id);
                        availableLots[matchedMat.Id] = lots;

                        var usedLots = selectedMaterials
                            .Where(existing => existing.MaterialId == matchedMat.Id)
                            .Select(existing => existing.TargetLotNumber)
                            .ToList();

                        var firstAvailLot = lots.FirstOrDefault(l => !usedLots.Contains(l.LotNumber)) ?? lots.FirstOrDefault();

                        var projMat = new ProjectMaterial
                        {
                            MaterialId = matchedMat.Id,
                            Name = matchedMat.Name,
                            Unit = matchedMat.Unit,
                            CustomPrice = aiMat.Price > 0 ? aiMat.Price : (firstAvailLot?.BasePrice ?? 0),
                            TotalQty = aiMat.Qty,
                            RemainingQty = aiMat.Qty,
                            ImageUrl = matchedMat.ImageUrl,
                            TargetLotNumber = firstAvailLot?.LotNumber ?? ""
                        };

                        selectedMaterials.Add(projMat);
                        
                        // Check cảnh báo tồn kho hứa hẹn luôn
                        await CheckPromisedAvailability(projMat);
                    }
                }
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private double CalculateSimilarity(string s1, string s2)
    {
        if (string.IsNullOrEmpty(s1) || string.IsNullOrEmpty(s2)) return 0;
        var words1 = s1.ToLower().Split(new[] { ' ', '-', ',', '.', '/' }, StringSplitOptions.RemoveEmptyEntries);
        var words2 = s2.ToLower().Split(new[] { ' ', '-', ',', '.', '/' }, StringSplitOptions.RemoveEmptyEntries);

        int matchCount = 0;
        foreach (var w1 in words1)
        {
            foreach (var w2 in words2)
            {
                if (w1 == w2 || w1.Contains(w2) || w2.Contains(w1))
                {
                    matchCount++;
                    break;
                }
            }
        }
        return (double)matchCount / Math.Max(words1.Length, words2.Length);
    }

    private async Task LoadData()
    {
        // Get all to calculate counts, but we'll filter in memory for smooth UX
        allProjects = await WarehouseService.GetProjectsAsync();
    }

    private void SetTab(bool completed)
    {
        showCompleted = completed;
        currentPage = 1;
    }

    private List<Project> filteredProjects => allProjects
        .Where(p => p.IsCompleted == showCompleted)
        .Where(p => string.IsNullOrWhiteSpace(searchText) || 
                    p.CustomerName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    (p.Phone?.Contains(searchText) ?? false) ||
                    (p.Address?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderByDescending(p => p.CreatedAt)
        .ToList();

    private IEnumerable<Project> PaginatedProjects => filteredProjects
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(filteredProjects.Count / (double)pageSize));

    private void OnCustomerSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            var c = customers.FirstOrDefault(x => x.Id == id);
            if (c != null)
            {
                newProject.CustomerId = c.Id;
                newProject.CustomerName = c.Name;
                newProject.Phone = c.Phone;
                newProject.Address = c.Address;
            }
        }
    }

    private async Task OnMaterialsSelected(List<Material> materials)
    {
        foreach (var m in materials)
        {
            var lots = await WarehouseService.GetMaterialLotsAsync(m.Id);
            availableLots[m.Id] = lots;

            // Tìm lô đầu tiên chưa được dùng cho vật tư này
            var usedLots = selectedMaterials
                .Where(existing => existing.MaterialId == m.Id)
                .Select(existing => existing.TargetLotNumber)
                .ToList();
            
            var firstAvailLot = lots.FirstOrDefault(l => !usedLots.Contains(l.LotNumber)) ?? lots.FirstOrDefault();

            selectedMaterials.Add(new ProjectMaterial 
            { 
                MaterialId = m.Id, 
                Name = m.Name, 
                Unit = m.Unit, 
                CustomPrice = firstAvailLot?.BasePrice ?? 0, 
                TotalQty = 0,
                RemainingQty = 0,
                ImageUrl = m.ImageUrl,
                TargetLotNumber = firstAvailLot?.LotNumber ?? ""
            });
        }
    }

    private void RemoveMaterial(ProjectMaterial sm) => selectedMaterials.Remove(sm);

    private void DuplicateMaterial(ProjectMaterial sm)
    {
        var lots = availableLots.ContainsKey(sm.MaterialId) ? availableLots[sm.MaterialId] : new List<MaterialLot>();
        
        // Tìm lô tiếp theo chưa dùng
        var usedLots = selectedMaterials
            .Where(existing => existing.MaterialId == sm.MaterialId)
            .Select(existing => existing.TargetLotNumber)
            .ToList();
        
        var nextLot = lots.FirstOrDefault(l => !usedLots.Contains(l.LotNumber)) ?? lots.FirstOrDefault();

        var index = selectedMaterials.IndexOf(sm);
        selectedMaterials.Insert(index + 1, new ProjectMaterial
        {
            MaterialId = sm.MaterialId,
            Name = sm.Name,
            Unit = sm.Unit,
            CustomPrice = sm.CustomPrice,
            TotalQty = sm.TotalQty,
            RemainingQty = sm.RemainingQty,
            ImageUrl = sm.ImageUrl,
            TargetLotNumber = nextLot?.LotNumber ?? ""
        });
    }

    private async Task SaveProject()
    {
        if (string.IsNullOrWhiteSpace(newProject.CustomerName)) return;
        foreach(var sm in selectedMaterials) sm.RemainingQty = sm.TotalQty;
        newProject.Materials = selectedMaterials;
        await WarehouseService.CreateProjectAsync(newProject);
        newProject = new();
        selectedMaterials = new();
        promisedWarnings.Clear();
        isAdding = false;
        await LoadData();
    }

    private async Task CheckPromisedAvailability(ProjectMaterial sm)
    {
        var matId = sm.MaterialId;
        var lotNum = sm.TargetLotNumber;
        
        // Lấy số lượng đã hứa ở các dự án khác
        var promisedOther = await WarehouseService.GetTotalPromisedQtyAsync(matId, lotNum);
        
        // Tổng hứa = Đã hứa các dự án khác + Dự kiến mới của dự án này (sm.TotalQty)
        var totalPromised = promisedOther + sm.TotalQty;
        
        // Lấy tồn kho thực tế
        double actualStock = 0;
        var mainMat = await WarehouseService.GetMaterialByIdAsync(matId);
        if (mainMat != null)
        {
            if (string.IsNullOrEmpty(lotNum))
            {
                actualStock = mainMat.StockQty;
            }
            else
            {
                var lot = mainMat.Lots.FirstOrDefault(l => l.LotNumber == lotNum);
                actualStock = lot?.StockQty ?? 0;
            }
        }
        
        if (totalPromised > actualStock + 0.0001)
        {
            var diff = totalPromised - actualStock;
            promisedWarnings[matId] = $"⚠️ Kho {(string.IsNullOrEmpty(lotNum) ? "tổng" : $"lô '{lotNum}'")} chỉ còn {actualStock.ToString("0.##")}. Tổng yêu cầu các dự án ({totalPromised.ToString("0.##")}) sẽ vượt {diff.ToString("0.##")}!";
        }
        else
        {
            promisedWarnings[matId] = null;
        }
        StateHasChanged();
    }
}
