@code {
    private List<Material> materials = new();
    private List<Category> categories = new();
    private List<Supplier> suppliers = new();
    private string searchText = "";
    private int? selectedCategoryId;
    private int? selectedSupplierId;
    private int currentPage = 1;
    private int pageSize = 12;

    private string viewMode = "grid";
    private bool isFormOpen = false;
    private bool showQRModal = false;
    private Material? qrMaterial;
    private string qrCodeUrl = "";

    private Material editingMaterial = new();
    private decimal editingCostPrice;
    private decimal editingBasePrice;
    private Dictionary<int, double> originalLotQtys = new(); // Lưu số lượng gốc để so sánh
    private Dictionary<int, (decimal Cost, decimal Base)> originalLotPrices = new();
    private string editingCategoryName = "";
    private Category? editingCategory;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        materials = await WarehouseService.GetMasterMaterialsAsync();
        categories = await WarehouseService.GetCategoriesAsync();
        suppliers = await WarehouseService.GetSuppliersAsync();
    }

    private List<Material> filteredMaterials => materials
        .Where(m => selectedCategoryId == null || m.CategoryId == selectedCategoryId)
        .Where(m => selectedSupplierId == null || m.SupplierId == selectedSupplierId)
        .Where(m => string.IsNullOrWhiteSpace(searchText) || 
                   m.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) || 
                   (m.ProductCode != null && m.ProductCode.Contains(searchText, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    private IEnumerable<Material> PaginatedMaterials => filteredMaterials.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(filteredMaterials.Count / (double)pageSize));

    private void ResetForm()
    {
        editingMaterial = new();
        editingCostPrice = 0;
        editingBasePrice = 0;
        isFormOpen = false;
    }

    private void RecalculateTotal()
    {
        if (editingMaterial.Lots != null && editingMaterial.Lots.Any())
        {
            editingMaterial.StockQty = editingMaterial.Lots.Sum(l => l.StockQty);
        }
    }

    private void AddNewLot()
    {
        if (editingMaterial.Lots == null) editingMaterial.Lots = new();
        
        editingMaterial.Lots.Add(new MaterialLot
        {
            MaterialId = editingMaterial.Id,
            LotNumber = $"Lô mới {DateTime.Now:dd/MM/yy HH:mm}",
            StockQty = 0,
            CostPrice = editingCostPrice,
            BasePrice = editingBasePrice,
            Note = "Thêm mới từ danh mục"
        });
    }

    private async Task EditMaterial(Material m)
    {
        var fresh = await WarehouseService.GetMaterialByIdAsync(m.Id);
        if (fresh != null)
        {
            editingMaterial = fresh;
            originalLotQtys = fresh.Lots.ToDictionary(l => l.Id, l => l.StockQty);
            originalLotPrices = fresh.Lots.ToDictionary(l => l.Id, l => (l.CostPrice, l.BasePrice));
            
            // Lấy giá từ lô đầu tiên làm mặc định cho form nếu cần (nhưng form giờ dùng cho tạo mới)
            var firstLot = fresh.Lots.OrderBy(l => l.Id).FirstOrDefault();
            if (firstLot != null) {
                editingCostPrice = firstLot.CostPrice;
                editingBasePrice = firstLot.BasePrice;
            }

            isFormOpen = true;
        }
    }

    private void ShowQR(Material m)
    {
        qrMaterial = m;
        // Sử dụng IP trực tiếp (VD: 192.168.1.15) thay vì .local để điện thoại quét phát ăn luôn
        // Và kèm theo cổng 5134 như cấu hình trong launchSettings
        var ip = WarehouseService.GetLocalIPAddress();
        qrCodeUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=https://{ip}:5134/material/{m.Id}";
        showQRModal = true;
    }


    private async Task SaveMaterial()
    {
        if (string.IsNullOrWhiteSpace(editingMaterial.Name)) return;
        
        // 1. Kiểm tra và cập nhật các lô có thay đổi số lượng hoặc giá TRƯỚC để ghi log
        if (editingMaterial.Id > 0)
        {
            foreach (var lot in editingMaterial.Lots.ToList())
            {
                if (lot.Id == 0)
                {
                    // Thêm lô mới
                    await WarehouseService.AddMaterialLotAsync(lot);
                }
                else
                {
                    // Cập nhật lô cũ
                    bool qtyChanged = originalLotQtys.ContainsKey(lot.Id) && originalLotQtys[lot.Id] != lot.StockQty;
                    bool priceChanged = originalLotPrices.ContainsKey(lot.Id) && (originalLotPrices[lot.Id].Cost != lot.CostPrice || originalLotPrices[lot.Id].Base != lot.BasePrice);
                    
                    if (qtyChanged || priceChanged)
                    {
                        await WarehouseService.UpdateMaterialLotFullAsync(lot);
                        
                        if (qtyChanged)
                        {
                            await WarehouseService.RecordInventoryTransactionAsync(new InventoryTransaction
                            {
                                MaterialId = editingMaterial.Id,
                                Type = "Điều chỉnh",
                                QtyChange = lot.StockQty - originalLotQtys[lot.Id],
                                Note = $"Điều chỉnh kho thủ công cho Lô: {lot.LotNumber}"
                            });
                        }
                    }
                }
            }
        }

        // 2. Lưu thông tin cơ bản của vật tư
        if (editingMaterial.Id == 0) await WarehouseService.AddMasterMaterialAsync(editingMaterial, editingCostPrice, editingBasePrice);
        else await WarehouseService.UpdateMasterMaterialAsync(editingMaterial);

        editingMaterial = new();
        originalLotQtys.Clear();
        await LoadData();
    }

    private async Task DeleteCategory(int id) { await WarehouseService.DeleteCategoryAsync(id); await LoadData(); }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var format = "image/png";
            var resizedImage = await file.RequestImageFileAsync(format, 400, 400);
            using var stream = resizedImage.OpenReadStream();
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            editingMaterial.ImageUrl = $"data:{format};base64,{Convert.ToBase64String(ms.ToArray())}";
        }
    }
}
