@using System.Data
@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="calc-modal-backdrop" @onclick="Close">
        <div class="calc-card glass-card" @onclick:stopPropagation>
            <div class="calc-header">
                <h3><i class="bi bi-calculator"></i> Máy tính - @Title</h3>
                <button class="btn-close" @onclick="Close"><i class="bi bi-x-lg"></i></button>
            </div>
            
            <div class="calc-display">
                <div class="expression">@expression</div>
                <div class="result">@displayValue</div>
            </div>
            
            <div class="calc-grid">
                <button class="btn-calc op" @onclick='() => Append(" / ")'>/</button>
                <button class="btn-calc op" @onclick='() => Append(" * ")'>x</button>
                <button class="btn-calc op" @onclick='() => Append(" - ")'>-</button>
                <button class="btn-calc op" @onclick='() => Append(" + ")'>+</button>
                
                <button class="btn-calc" @onclick='() => Append("7")'>7</button>
                <button class="btn-calc" @onclick='() => Append("8")'>8</button>
                <button class="btn-calc" @onclick='() => Append("9")'>9</button>
                <button class="btn-calc danger" @onclick="Clear">C</button>
                
                <button class="btn-calc" @onclick='() => Append("4")'>4</button>
                <button class="btn-calc" @onclick='() => Append("5")'>5</button>
                <button class="btn-calc" @onclick='() => Append("6")'>6</button>
                <button class="btn-calc op" @onclick="Calculate">=</button>
                
                <button class="btn-calc" @onclick='() => Append("1")'>1</button>
                <button class="btn-calc" @onclick='() => Append("2")'>2</button>
                <button class="btn-calc" @onclick='() => Append("3")'>3</button>
                <button class="btn-calc success" @onclick="Apply">OK</button>
                
                <button class="btn-calc zero" @onclick='() => Append("0")'>0</button>
                <button class="btn-calc" @onclick='() => Append(".")'>.</button>
            </div>
        </div>
    </div>
}

<style>
    .calc-modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
    }
    
    .calc-card {
        width: 320px;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid var(--border-color);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
    
    .calc-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }
    
    .calc-header h3 { margin: 0; font-size: 1rem; font-weight: 700; color: var(--text-primary); }
    
    .btn-close {
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 1.25rem;
    }
    
    .calc-display {
        background: #f1f5f9;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        text-align: right;
        min-height: 80px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    
    .expression { font-size: 0.875rem; color: var(--text-muted); min-height: 1.2rem; }
    .result { font-size: 1.75rem; font-weight: 800; color: var(--text-primary); }
    
    .calc-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
    }
    
    .btn-calc {
        height: 50px;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        background: white;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-primary);
        cursor: pointer;
        transition: all 0.1s;
    }
    
    .btn-calc:active { transform: scale(0.95); }
    .btn-calc:hover { background: #f8fafc; }
    
    .btn-calc.op { background: #eff6ff; color: var(--accent-primary); }
    .btn-calc.danger { background: #fef2f2; color: var(--error); }
    .btn-calc.success { background: var(--accent-primary); color: white; grid-row: span 2; height: 108px; }
    .btn-calc.zero { grid-column: span 2; }
</style>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public EventCallback<double> OnResult { get; set; }
    
    private string expression = "";
    private string displayValue = "0";
    
    private void Append(string val)
    {
        if (displayValue == "0" && !val.Contains(".") && val != " / " && val != " * " && val != " - " && val != " + ")
            displayValue = val;
        else
            displayValue += val;
    }
    
    private void Clear()
    {
        expression = "";
        displayValue = "0";
    }
    
    private void Calculate()
    {
        try
        {
            expression = displayValue;
            var dt = new DataTable();
            var result = dt.Compute(displayValue, "");
            displayValue = Convert.ToDouble(result).ToString("G10");
        }
        catch
        {
            displayValue = "Error";
        }
    }
    
    private async Task Apply()
    {
        Calculate();
        if (double.TryParse(displayValue, out double val))
        {
            await OnResult.InvokeAsync(val);
            await Close();
        }
    }
    
    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }
}
