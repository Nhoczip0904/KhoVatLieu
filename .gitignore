## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://learn.microsoft.com/en-us/visualstudio/ide/finding-and-using-visual-studio-project-templates for more information.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv][Ss][Pp][Ss][Cc][Cc]

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build logs
*.log

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*.lastcodeanalysissucceeded
*.NetRequestHandler.diag
*.mdf
*.ldf
*.ndf

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Repository Config
# .nuget/
# NuGet.Config
# NuGet.exe

# BUCK
.buckd/
*.keystore
!public.keystore
build/
bin/
gen/
out/

# JetBrains Resharper
*.ReSharper.user
_ReSharper*/

# JetBrains Rider
.idea/

# Local Config files
appsettings.Local.json

# SQLite databases
*.db
*.db-shm
*.db-wal

# Build/Publish outputs
[Pp]ublish_test/
*.exe
*.dll
*.pdb
